# ============================================================
# Area Nuova — variabili d'ambiente
# Copia questo file in .env (locale) o configura le stesse chiavi
# nel pannello Vercel → Settings → Environment Variables.
# Nessun valore reale in questo file: solo nomi, obbligatorietà e
# ambito (client = spedita al browser, server = solo lato server).
# ============================================================

# --- Supabase — client browser (obbligatorie) ---------------
# Ambito: CLIENT (prefisso PUBLIC_, finiscono nel bundle spedito al browser)
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase — solo server (obbligatoria per le funzioni Aris) ---
# Ambito: SERVER — non deve MAI essere letta da codice che gira nel browser.
# Usata da src/lib/aris/supabase-admin.ts e dagli script scripts/*.mjs.
SUPABASE_SERVICE_ROLE_KEY=

# --- Decap CMS — OAuth GitHub (obbligatorie se si usa /admin) ---
# Ambito: SERVER — usate da src/pages/api/auth.ts e callback.ts.
# GITHUB_CLIENT_ID / GITHUB_CLIENT_SECRET: creati registrando una GitHub
# OAuth App su https://github.com/settings/developers (Authorization
# callback URL = REDIRECT_URI sotto).
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# URL completo del callback OAuth, es. https://www.associazioneareanuova.it/api/callback
REDIRECT_URI=

# --- Pannello CMS unificato (Sprint 3) — commit automatici su GitHub ---
# Ambito: SERVER — usata solo da src/lib/admin/github.ts, mai raggiungibile
# dal browser. Diversa da GITHUB_CLIENT_ID/SECRET sopra: quelle autenticano
# il LOGIN di un utente Decap; questa autentica il SERVER quando scrive un
# file per conto di un editor del pannello CMS. Un Personal Access Token
# fine-grained: repository Settings → Developer settings → Personal access
# tokens → Fine-grained tokens; "Repository access" limitato SOLO al
# repository di questo progetto; permesso "Contents: Read and write";
# nessun altro permesso; nessun accesso ad altri repository. NON configurata
# in questo ambiente: finché manca, il pannello valida e mostra un'anteprima
# ma non pubblica su GitHub — vedi docs/CMS_SPRINT_3.md.
GITHUB_SERVICE_TOKEN=

# Repository di destinazione dei commit del pannello CMS (Sprint 3.1).
# Ambito: SERVER. Opzionali: se assenti, il codice usa di default il
# repository reale su cui gira questo progetto (owner/nome attuali,
# branch "main") — impostale solo se serve puntare altrove.
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
GITHUB_REPO_BRANCH=

# --- Provider AI — almeno uno richiesto se Aris è attivo -----
# Ambito: SERVER. AI_PROVIDER seleziona quale usare (default 'openai').
AI_PROVIDER=

# OpenAI (richiesta se AI_PROVIDER=openai, o per lo script aris:index che
# genera sempre gli embedding via OpenAI indipendentemente da AI_PROVIDER)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=
OPENAI_CHAT_MODEL=

# Gemini (richiesta se AI_PROVIDER=gemini) — nota: GeminiProvider non
# supporta generateEmbedding() (incompatibilità dimensionale con la colonna
# pgvector a 1536 dimensioni) — vedi docs/ADMIN_FOUNDATIONS.md.
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=

# OpenRouter (opzionale — fallback automatico quando AI_PROVIDER=gemini
# e la chiamata Gemini fallisce per quota/rate-limit)
OPENROUTER_API_KEY=
OPENROUTER_CHAT_MODEL=

# --- Aris — segreti admin (opzionali, ma consigliati se Aris è attivo) ---
# Ambito: SERVER. Tre segreti distinti con scopi diversi — non intercambiabili:
# ARIS_ADMIN_SECRET: password della dashboard /admin/aris (header x-admin-secret).
#   Se non impostata, /admin/aris resta permanentemente inaccessibile (fail-closed).
ARIS_ADMIN_SECRET=
# ARIS_ADMIN_KEY: autorizza POST /api/index-content e (in alternativa a
#   CRON_SECRET) POST /api/aris/sync-external, via header "Authorization: Bearer ...".
#   Se non impostata, /api/index-content NON richiede autenticazione (fail-open —
#   vedi rischio in docs/ADMIN_FOUNDATIONS.md).
ARIS_ADMIN_KEY=
# CRON_SECRET: autorizza il cron job Vercel su /api/aris/sync-external
#   (schedulato in vercel.json). Impostata automaticamente da Vercel per i
#   cron nativi in molti setup — verificare se è già presente prima di
#   generarne una nuova.
CRON_SECRET=
