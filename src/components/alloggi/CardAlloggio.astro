---
interface Props {
  id: string;
  titolo: string;
  tipo: string;
  citta: string;
  zona?: string | null;
  prezzo: number;
  spese_incluse: boolean;
  disponibile_da?: string | null;
  foto_url?: string | null;
}

const TIPO_LABEL: Record<string, string> = {
  stanza_singola: 'Stanza singola',
  stanza_doppia: 'Stanza doppia',
  posto_letto: 'Posto letto',
  monolocale: 'Monolocale',
  bilocale: 'Bilocale',
  appartamento: 'Appartamento intero',
  altro: 'Altro',
};

const {
  id, titolo, tipo, citta, zona, prezzo,
  spese_incluse, disponibile_da, foto_url,
} = Astro.props;

const tipoLabel = TIPO_LABEL[tipo] ?? tipo;
const localita = zona ? `${citta} — ${zona}` : citta;
const dettaglioHref = `/alloggi/${id}`;

let disponibileLabel: string | null = null;
if (disponibile_da) {
  disponibileLabel = new Intl.DateTimeFormat('it-IT', {
    day: 'numeric', month: 'long', year: 'numeric',
  }).format(new Date(disponibile_da + 'T00:00:00'));
}
---

<article class="group flex flex-col overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-slate-200 transition-transform duration-200 motion-reduce:transition-none hover:-translate-y-1 motion-reduce:hover:translate-y-0">

  <!-- Foto o fallback -->
  <div class="relative h-44 w-full overflow-hidden bg-slate-100">
    {foto_url ? (
      <img
        src={foto_url}
        alt={titolo}
        class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105 motion-reduce:transition-none motion-reduce:group-hover:scale-100"
        loading="lazy"
      />
    ) : (
      <div class="flex h-full w-full items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"
          stroke-linejoin="round" class="text-slate-300">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
          <polyline points="9 22 9 12 15 12 15 22" />
        </svg>
      </div>
    )}
    <!-- Badge tipo sovrapposto alla foto -->
    <span class="absolute left-3 top-3 rounded-full bg-white/90 px-2.5 py-1 text-xs font-semibold text-slate-800 shadow-sm backdrop-blur-sm">
      {tipoLabel}
    </span>
  </div>

  <!-- Corpo -->
  <div class="flex flex-1 flex-col p-5">
    <h3 class="line-clamp-2 text-base font-bold text-slate-900">{titolo}</h3>

    <p class="mt-1 flex items-center gap-1.5 text-sm text-slate-500">
      <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24"
        fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
        stroke-linejoin="round" class="shrink-0">
        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
        <circle cx="12" cy="10" r="3" />
      </svg>
      {localita}
    </p>

    <div class="mt-3">
      <p class="text-2xl font-bold text-slate-900">
        €{prezzo}<span class="text-sm font-normal text-slate-500">/mese</span>
      </p>
      {spese_incluse && (
        <span class="mt-1.5 inline-block rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-semibold text-green-800">
          Spese incluse
        </span>
      )}
    </div>

    {disponibileLabel && (
      <p class="mt-2 text-xs text-slate-500">Disponibile dal {disponibileLabel}</p>
    )}

    <a
      href={dettaglioHref}
      class="mt-4 w-full rounded-xl bg-primary-800 px-4 py-2.5 text-center text-sm font-semibold text-white hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2"
    >
      Vedi dettagli
    </a>
  </div>

</article>
