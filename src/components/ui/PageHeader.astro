---
interface Props {
  titolo: string;
  sottotitolo?: string;
  occhiello?: string;
}
const { titolo, sottotitolo, occhiello } = Astro.props;
---

<section class="border-b border-slate-200 bg-gradient-to-b from-primary-50 to-white">
  <div class="container-site py-12 sm:py-16">
    {occhiello && (
      <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-accent-600">{occhiello}</p>
    )}
    <h1 class="text-3xl font-bold sm:text-4xl">{titolo}</h1>
    {sottotitolo && (
      <p class="mt-4 max-w-2xl text-lg text-slate-600">{sottotitolo}</p>
    )}
  </div>
</section>
