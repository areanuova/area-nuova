---
import type { CollectionEntry } from 'astro:content';

interface Props {
  rappresentante: CollectionEntry<'rappresentanti'>;
}

const { rappresentante } = Astro.props;
const { nome, ruolo, organo, dipartimento, foto, email } = rappresentante.data;

const etichettaOrgano: Record<string, string> = {
  senato: 'Senato Accademico',
  cda: 'Consiglio di Amministrazione',
  csu: 'Consiglio degli Studenti',
  nucleo: 'Nucleo di Valutazione',
  adisu: 'CdA ADISU Puglia',
  dipartimento: 'Consiglio di Dipartimento',
  corso: 'Consiglio di Corso',
};

const iniziali = nome.split(' ').map((p) => p[0]).slice(0, 2).join('').toUpperCase();
const categoria = [organo, dipartimento].filter(Boolean).join('|');
---

<article
  data-cat={categoria}
  class="group flex flex-col items-center rounded-2xl bg-white p-6 text-center shadow-sm ring-1 ring-slate-200"
>
  {foto ? (
    <img src={foto} alt={nome} width="120" height="120" class="card-avatar h-28 w-28 rounded-full object-cover" loading="lazy" />
  ) : (
    <div class="card-avatar grid h-28 w-28 place-items-center rounded-full bg-primary-100 font-display text-2xl font-bold text-primary-800">
      {iniziali}
    </div>
  )}

  <h3 class="mt-4 text-lg font-bold">{nome}</h3>
  <p class="text-sm font-medium text-accent-600">{ruolo}</p>
  <p class="mt-1 text-xs text-slate-500">{etichettaOrgano[organo]}{dipartimento ? ` · ${dipartimento}` : ''}</p>

  {email && (
    <a href={`mailto:${email}`} class="mt-4 text-sm font-semibold text-primary-800 hover:underline">
      Scrivi una mail
    </a>
  )}
</article>

<style>
  article {
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  article:hover {
    transform: translateY(-4px);
    box-shadow:
      0 0 0 1px rgba(189, 204, 220, 0.8),
      0 8px 24px rgba(0, 48, 96, 0.10),
      0 20px 48px rgba(0, 0, 0, 0.07);
  }
  .card-avatar {
    transition: transform 0.3s ease;
  }
  article:hover .card-avatar {
    transform: scale(1.05);
  }
  @media (prefers-reduced-motion: reduce) {
    article { transition: box-shadow 0.25s ease; }
    article:hover { transform: none; }
    .card-avatar { transition: none; }
    article:hover .card-avatar { transform: none; }
  }
</style>
