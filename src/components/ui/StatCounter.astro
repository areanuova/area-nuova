---
interface Props {
  valore: number;
  etichetta: string;
  suffisso?: string;
}
const { valore, etichetta, suffisso = '' } = Astro.props;
---

<div class="rounded-2xl bg-white p-6 text-center shadow-sm ring-1 ring-slate-200">
  <div
    class="stat-number font-display text-4xl font-bold text-primary-800 sm:text-5xl"
    data-target={valore}
    data-suffix={suffisso}
  >
    0{suffisso}
  </div>
  <p class="mt-2 text-sm font-medium text-slate-600">{etichetta}</p>
</div>

<script>
  // Anima i numeri quando entrano nello schermo
  const animate = (el: HTMLElement) => {
    const target = Number(el.dataset.target || 0);
    const suffix = el.dataset.suffix || '';
    const durata = 1200;
    const inizio = performance.now();
    const step = (ora: number) => {
      const p = Math.min((ora - inizio) / durata, 1);
      const eased = 1 - Math.pow(1 - p, 3);
      el.textContent = Math.round(target * eased) + suffix;
      if (p < 1) requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
  };

  const numeri = document.querySelectorAll<HTMLElement>('.stat-number');
  const obs = new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      if (e.isIntersecting) {
        animate(e.target as HTMLElement);
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.5 });
  numeri.forEach((n) => obs.observe(n));
</script>
