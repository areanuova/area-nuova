---
import { Image } from 'astro:assets';
import Badge from './Badge.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  progetto: CollectionEntry<'progetti'>;
}
const { progetto } = Astro.props;
const { titolo, descrizione, stato, categoria, copertina } = progetto.data;
---

<article
  data-cat={categoria}
  class="group relative flex flex-col overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-slate-200"
>
  {copertina && (
    <Image src={copertina} alt={titolo} width={600} height={340} class="card-cover h-44 w-full object-cover" />
  )}
  <div class="flex flex-1 flex-col p-6">
    <div class="mb-3 flex items-center gap-2">
      <Badge variante={stato === 'attivo' ? 'accent' : 'neutro'}>
        {stato === 'attivo' ? 'In corso' : 'Concluso'}
      </Badge>
      <Badge variante="primary">{categoria}</Badge>
    </div>
    <h3 class="text-lg font-bold">
      <a href={`/progetti/${progetto.slug}`} class="after:absolute after:inset-0 group-hover:text-primary-800">
        {titolo}
      </a>
    </h3>
    <p class="mt-2 flex-1 text-sm text-slate-600">{descrizione}</p>
    <span class="mt-4 text-sm font-semibold text-primary-800">Scopri di più →</span>
  </div>
</article>

<style>
  article {
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  article:hover {
    transform: translateY(-4px);
    box-shadow:
      0 0 0 1px rgba(189, 204, 220, 0.8),
      0 8px 24px rgba(0, 48, 96, 0.10),
      0 20px 48px rgba(0, 0, 0, 0.07);
  }
  :global(.card-cover) {
    transition: transform 0.45s ease;
  }
  article:hover :global(.card-cover) {
    transform: scale(1.04);
  }
  @media (prefers-reduced-motion: reduce) {
    article { transition: box-shadow 0.25s ease; }
    article:hover { transform: none; }
    :global(.card-cover) { transition: none; }
    article:hover :global(.card-cover) { transform: none; }
  }
</style>
