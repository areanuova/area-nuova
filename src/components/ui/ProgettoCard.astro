---
import { Image } from 'astro:assets';
import Badge from './Badge.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  progetto: CollectionEntry<'progetti'>;
}
const { progetto } = Astro.props;
const { titolo, descrizione, stato, categoria, copertina } = progetto.data;
---

<article
  data-cat={categoria}
  class="group relative flex flex-col overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-slate-200 transition-shadow hover:shadow-lg"
>
  {copertina && (
    <Image src={copertina} alt={titolo} width={600} height={340} class="h-44 w-full object-cover" />
  )}
  <div class="flex flex-1 flex-col p-6">
    <div class="mb-3 flex items-center gap-2">
      <Badge variante={stato === 'attivo' ? 'accent' : 'neutro'}>
        {stato === 'attivo' ? 'In corso' : 'Concluso'}
      </Badge>
      <Badge variante="primary">{categoria}</Badge>
    </div>
    <h3 class="text-lg font-bold">
      <a href={`/progetti/${progetto.slug}`} class="after:absolute after:inset-0 group-hover:text-primary-800">
        {titolo}
      </a>
    </h3>
    <p class="mt-2 flex-1 text-sm text-slate-600">{descrizione}</p>
    <span class="mt-4 text-sm font-semibold text-primary-800">Scopri di più →</span>
  </div>
</article>
