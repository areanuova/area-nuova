---
import sito from '../../data/sito.json';
const anno = new Date().getFullYear();

const colonne = [
  {
    titolo: 'Associazione',
    voci: [
      { href: '/chi-siamo', testo: 'Chi siamo' },
      { href: '/rappresentanti', testo: 'Rappresentanti' },
      { href: '/progetti', testo: 'Progetti e risultati' },
      { href: '/entra', testo: 'Entra in Area Nuova' },
      { href: '/admin/alloggi', testo: 'Area riservata' },
    ],
  },
  {
    titolo: 'Per gli studenti',
    voci: [
      { href: '/guide', testo: 'Guide utili' },
      { href: '/modulistica', testo: 'Modulistica e mozioni' },
      { href: '/segnalazioni', testo: 'Segnalazioni' },
      { href: '/eventi', testo: 'Eventi' },
      { href: '/convenzioni', testo: 'Discount Card' },
      { href: '/partnership', testo: 'Partnership' },
      { href: '/alloggi', testo: 'Alloggi' },
      { href: '/gruppi-whatsapp', testo: 'Gruppi WhatsApp' },
      { href: '/video', testo: 'Video' },
    ],
  },
];
---

<footer class="mt-24 border-t border-slate-200 bg-white">
  <div class="container-site grid gap-10 py-12 md:grid-cols-4">
    <div class="md:col-span-2">
      <img src="/images/logo-scritta.png" alt={sito.nome} class="h-10 w-auto" width="441" height="133" />
      <p class="mt-3 max-w-sm text-sm text-slate-600">{sito.descrizione}</p>
      <p class="mt-4 text-sm text-slate-600">
        <a href={`mailto:${sito.email}`} class="font-medium text-primary-800 hover:underline">{sito.email}</a>
      </p>
      <div class="mt-4 flex items-center gap-3">
        {sito.social.instagram && <a href={sito.social.instagram} class="text-sm text-slate-500 hover:text-primary-800">Instagram</a>}
        {sito.social.facebook && <a href={sito.social.facebook} class="text-sm text-slate-500 hover:text-primary-800">Facebook</a>}
        {sito.social.telegram && <a href={sito.social.telegram} class="text-sm text-slate-500 hover:text-primary-800">Telegram</a>}
        {sito.social.youtube && (
          <a href={sito.social.youtube} target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="flex items-center gap-1 text-sm text-slate-500 hover:text-primary-800">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31.5 31.5 0 0 0 0 12a31.5 31.5 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31.5 31.5 0 0 0 24 12a31.5 31.5 0 0 0-.5-5.8ZM9.6 15.5v-7l6.3 3.5-6.3 3.5Z"/></svg>
            YouTube
          </a>
        )}
      </div>
    </div>

    {colonne.map((col) => (
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wide text-slate-900">{col.titolo}</h3>
        <ul class="mt-4 space-y-2">
          {col.voci.map((v) => (
            <li><a href={v.href} class="text-sm text-slate-600 hover:text-primary-800">{v.testo}</a></li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  <div class="border-t border-slate-200 py-6">
    <p class="container-site text-center text-xs text-slate-500">
      &copy; {anno} {sito.nome} · {sito.cittaUniversita}
    </p>
    <p class="container-site mt-2 text-center text-xs text-slate-400">
      Area Nuova è un'associazione studentesca autonoma. Il sito non è un portale istituzionale dell'Università di Foggia.
    </p>
  </div>
</footer>
