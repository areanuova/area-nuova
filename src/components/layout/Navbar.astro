---
import sito from '../../data/sito.json';

const mainLinks = [
  { href: '/chi-siamo', testo: 'Chi siamo' },
  { href: '/rappresentanti', testo: 'Rappresentanti' },
  { href: '/progetti', testo: 'Progetti' },
  { href: '/guide', testo: 'Guide' },
  { href: '/convenzioni', testo: 'Convenzioni' },
];

const altroLinks = [
  { href: '/news', testo: 'News e Comunicati' },
  { href: '/eventi', testo: 'Eventi' },
  { href: '/modulistica', testo: 'Mozioni e Documenti' },
  { href: '/contatti', testo: 'Contatti' },
];

const allLinks = [...mainLinks, ...altroLinks];

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);

const altroIsActive = altroLinks.some((l) => isActive(l.href));
---

<header class="sticky top-0 z-50 border-b border-slate-200 bg-white/90 backdrop-blur">
  <nav class="container-site flex h-16 items-center justify-between gap-4">
    <!-- Logo -->
    <a href="/" class="flex shrink-0 items-center" aria-label={sito.nome}>
      <img src="/images/logo-scritta.png" alt={sito.nome} class="h-9 w-auto" width="441" height="133" />
    </a>

    <!-- Menu desktop -->
    <ul class="hidden items-center gap-1 lg:flex">
      {mainLinks.map((l) => (
        <li>
          <a
            href={l.href}
            class:list={[
              'rounded-lg px-3 py-2 text-sm font-medium transition-colors',
              isActive(l.href)
                ? 'bg-primary-50 text-primary-800'
                : 'text-slate-600 hover:bg-slate-100 hover:text-primary-800',
            ]}
          >
            {l.testo}
          </a>
        </li>
      ))}

      <!-- Dropdown Altro -->
      <li class="relative">
        <button
          id="altro-toggle"
          class:list={[
            'flex items-center gap-1 rounded-lg px-3 py-2 text-sm font-medium transition-colors',
            altroIsActive
              ? 'bg-primary-50 text-primary-800'
              : 'text-slate-600 hover:bg-slate-100 hover:text-primary-800',
          ]}
          aria-expanded="false"
          aria-haspopup="true"
        >
          Altro
          <svg
            id="altro-chevron"
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="transition-transform duration-200"
          >
            <polyline points="6 9 12 15 18 9" />
          </svg>
        </button>

        <div
          id="altro-dropdown"
          class="absolute right-0 top-full mt-1 hidden min-w-[210px] rounded-xl border border-slate-200 bg-white py-1 shadow-md"
          role="menu"
        >
          {altroLinks.map((l) => (
            <a
              href={l.href}
              role="menuitem"
              class:list={[
                'block px-4 py-2 text-sm font-medium transition-colors',
                isActive(l.href)
                  ? 'bg-primary-50 text-primary-800'
                  : 'text-slate-600 hover:bg-slate-100 hover:text-primary-800',
              ]}
            >
              {l.testo}
            </a>
          ))}
        </div>
      </li>
    </ul>

    <!-- CTA desktop -->
    <div class="hidden shrink-0 items-center gap-2 lg:flex">
      <a
        href="/segnalazioni"
        class="rounded-lg px-3 py-2 text-sm font-semibold text-primary-800 transition-colors hover:bg-primary-50"
      >
        Segnala
      </a>
      <a
        href="/entra"
        class="rounded-lg bg-accent-500 px-4 py-2 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-accent-600"
      >
        Entra in Area Nuova
      </a>
    </div>

    <!-- Pulsante hamburger mobile -->
    <button
      id="menu-toggle"
      class="grid h-10 w-10 place-items-center rounded-lg text-slate-700 hover:bg-slate-100 lg:hidden"
      aria-label="Apri menu"
      aria-expanded="false"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </button>
  </nav>

  <!-- Menu mobile: tutte le voci piatte -->
  <div id="mobile-menu" class="hidden border-t border-slate-200 bg-white lg:hidden">
    <ul class="container-site flex flex-col gap-1 py-4">
      {allLinks.map((l) => (
        <li>
          <a
            href={l.href}
            class="block rounded-lg px-3 py-2 text-base font-medium text-slate-700 hover:bg-slate-100"
          >
            {l.testo}
          </a>
        </li>
      ))}
      <li class="mt-2 flex gap-2">
        <a
          href="/segnalazioni"
          class="flex-1 rounded-lg border border-primary-200 px-3 py-2 text-center text-sm font-semibold text-primary-800"
        >
          Segnala
        </a>
        <a
          href="/entra"
          class="flex-1 rounded-lg bg-accent-500 px-3 py-2 text-center text-sm font-semibold text-white"
        >
          Entra
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  // Mobile menu
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const nowHidden = menu?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!nowHidden));
  });

  // Desktop dropdown "Altro"
  const altroToggle = document.getElementById('altro-toggle') as HTMLButtonElement | null;
  const altroDropdown = document.getElementById('altro-dropdown');
  const altroChevron = document.getElementById('altro-chevron') as SVGElement | null;

  function openAltro() {
    altroDropdown?.classList.remove('hidden');
    altroChevron?.style.setProperty('transform', 'rotate(180deg)');
    altroToggle?.setAttribute('aria-expanded', 'true');
  }

  function closeAltro() {
    altroDropdown?.classList.add('hidden');
    altroChevron?.style.setProperty('transform', '');
    altroToggle?.setAttribute('aria-expanded', 'false');
  }

  altroToggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    altroDropdown?.classList.contains('hidden') ? openAltro() : closeAltro();
  });

  document.addEventListener('click', (e) => {
    if (
      !altroToggle?.contains(e.target as Node) &&
      !altroDropdown?.contains(e.target as Node)
    ) {
      closeAltro();
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeAltro();
  });
</script>
