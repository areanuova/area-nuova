---
// Widget Aris — assistente AI di Area Nuova
---

<div id="aris-root">
  <!-- Floating Action Button -->
  <button
    id="aris-fab"
    class="aris-fab"
    aria-label="Chiedi ad Aris, l'assistente di Area Nuova"
    aria-expanded="false"
    aria-controls="aris-panel"
  >
    <div class="aris-fab-face" aria-hidden="true">
      <img src="/images/aris/aris-face.png" class="aris-face-img" alt="Aris"/>
    </div>
    <span>Aris</span>
  </button>

  <!-- Chat Panel -->
  <div
    id="aris-panel"
    class="aris-panel"
    role="dialog"
    aria-modal="true"
    aria-label="Aris — Assistente Area Nuova"
    aria-hidden="true"
  >
    <!-- Header -->
    <div class="aris-header">
      <div class="aris-header-brand">
        <div class="aris-header-avatar" aria-hidden="true">
          <img src="/images/aris/aris-face.png" class="aris-face-img" alt="Aris"/>
        </div>
        <div>
          <p class="aris-name">Aris</p>
          <p class="aris-subtitle" id="aris-subtitle-txt">Assistente di Area Nuova</p>
        </div>
      </div>
      <div class="aris-header-actions">
        <button id="aris-prefs-btn" class="aris-icon-btn" aria-label="Impostazioni profilo" title="Profilo">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
          </svg>
        </button>
        <button id="aris-reset" class="aris-icon-btn" aria-label="Nuova conversazione" title="Nuova conversazione">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <polyline points="23 4 23 10 17 10"/>
            <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
          </svg>
        </button>
        <button id="aris-close" class="aris-icon-btn" aria-label="Chiudi Aris" title="Chiudi">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Prefs Panel (inline, sopra i messaggi) -->
    <div id="aris-prefs-panel" class="aris-prefs-panel" aria-hidden="true">
      <p class="aris-prefs-title">Il tuo profilo studente</p>
      <div class="aris-prefs-fields">
        <label class="aris-prefs-label">
          Corso di laurea
          <input id="aris-pref-corso" class="aris-prefs-input" type="text" placeholder="es. Medicina, Economia…" maxlength="80"/>
        </label>
        <label class="aris-prefs-label">
          Anno
          <select id="aris-pref-anno" class="aris-prefs-select">
            <option value="">—</option>
            <option>1° anno</option>
            <option>2° anno</option>
            <option>3° anno</option>
            <option>4° anno</option>
            <option>5° anno</option>
            <option>6° anno</option>
            <option>Magistrale</option>
            <option>Dottorato</option>
          </select>
        </label>
      </div>
      <div class="aris-prefs-footer">
        <button id="aris-prefs-save" class="aris-prefs-save-btn">Salva profilo</button>
        <button id="aris-prefs-close" class="aris-icon-btn-sm">Annulla</button>
      </div>
    </div>

    <!-- Messages -->
    <div id="aris-messages" class="aris-messages" role="log" aria-live="polite" aria-relevant="additions">
      <!-- Welcome -->
      <div id="aris-welcome">
        <div class="aris-welcome-icon" aria-hidden="true">
          <img src="/images/aris/aris-face.png" class="aris-face-img" alt="Aris"/>
        </div>
        <p class="aris-welcome-title">Ciao! Sono <strong>Aris</strong></p>
        <p class="aris-welcome-sub">Il tuo assistente per l'Università di Foggia.<br/>Cosa vorresti sapere?</p>
        <div class="aris-chips" role="list" aria-label="Suggerimenti">
          <button class="aris-chip" role="listitem" data-q="Come funziona la borsa di studio ADISU a Foggia?">📚 Borsa ADISU</button>
          <button class="aris-chip" role="listitem" data-q="Come trovo un alloggio per studenti a Foggia?">🏠 Alloggi studenti</button>
          <button class="aris-chip" role="listitem" data-q="Come funziona il semestre filtro di Medicina e Odontoiatria?">👨‍⚕️ Semestre filtro</button>
          <button class="aris-chip" role="listitem" data-q="Come funziona la Discount Card di Area Nuova?">💳 Discount Card</button>
          <button class="aris-chip" role="listitem" data-q="Come mi iscrivo a un esame su Esse3?">📅 Iscrizione esami</button>
          <button class="aris-chip" role="listitem" data-q="Come entro in un gruppo WhatsApp del mio corso?">👥 Gruppi WhatsApp</button>
        </div>
      </div>
    </div>

    <!-- Input area -->
    <div class="aris-input-area">
      <textarea
        id="aris-textarea"
        class="aris-textarea"
        placeholder="Chiedi qualcosa sull'università…"
        rows="1"
        maxlength="1000"
        aria-label="Scrivi la tua domanda"
      ></textarea>
      <button id="aris-send" class="aris-send-btn" aria-label="Invia" disabled>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <line x1="22" y1="2" x2="11" y2="13"/>
          <polygon points="22 2 15 22 11 13 2 9 22 2"/>
        </svg>
      </button>
    </div>
    <p class="aris-foot-note">Aris usa solo fonti interne — verifica sempre i dati ufficiali</p>
  </div>
</div>

<style is:global>
/* ── ARIS WIDGET ─────────────────────────────────────── */
#aris-root { position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 9990; }
#aris-root * { box-sizing: border-box; }

/* FAB */
.aris-fab {
  display: flex; align-items: center; gap: 0.5rem;
  padding: 0.7rem 1.2rem;
  background: #003c78; color: white;
  border: none; border-radius: 9999px;
  font-family: 'Space Grotesk', system-ui, sans-serif;
  font-size: 0.875rem; font-weight: 700;
  cursor: pointer; white-space: nowrap;
  box-shadow: 0 4px 18px rgba(0,60,120,.35);
  transition: transform .2s, box-shadow .2s;
}
.aris-fab:hover { transform: translateY(-2px); box-shadow: 0 6px 22px rgba(0,60,120,.45); }
.aris-fab:active { transform: none; }

/* Panel */
.aris-panel {
  position: fixed; bottom: 5.25rem; right: 1.5rem;
  width: 390px; max-height: 610px;
  display: flex; flex-direction: column;
  background: #fff; border-radius: 1.25rem;
  border: 1px solid #e2e8f0;
  box-shadow: 0 12px 48px rgba(0,0,0,.18);
  overflow: hidden;
  transform-origin: bottom right;
  transform: scale(.94) translateY(8px);
  opacity: 0; pointer-events: none;
  transition: opacity .22s cubic-bezier(.4,0,.2,1), transform .22s cubic-bezier(.4,0,.2,1);
}
.aris-panel.is-open {
  transform: scale(1) translateY(0);
  opacity: 1; pointer-events: all;
}
@media (max-width: 639px) {
  .aris-panel {
    position: fixed; inset: 0; bottom: 0; right: 0;
    width: 100%; max-height: 100%;
    border-radius: 0; transform-origin: bottom center;
  }
  .aris-fab-face { width: 44px; height: 44px; }
}

/* Header */
.aris-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: .8rem 1rem;
  background: linear-gradient(135deg, #003c78 0%, #124a81 100%);
  flex-shrink: 0;
}
.aris-header-brand { display: flex; align-items: center; gap: .6rem; }
.aris-header-avatar {
  width: 48px; height: 48px; border-radius: 50%;
  background: rgba(255,255,255,.15);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; overflow: hidden;
}
.aris-name {
  font-family: 'Space Grotesk', system-ui, sans-serif;
  font-size: .95rem; font-weight: 700; color: #fff; margin: 0; line-height: 1.2;
}
.aris-subtitle { font-size: .68rem; color: rgba(255,255,255,.7); margin: 0; }
.aris-header-actions { display: flex; gap: .2rem; }
.aris-icon-btn {
  width: 30px; height: 30px; border-radius: 7px;
  background: transparent; border: none;
  color: rgba(255,255,255,.75); cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: background .15s, color .15s;
}
.aris-icon-btn:hover { background: rgba(255,255,255,.15); color: #fff; }
.aris-icon-btn.is-active { background: rgba(255,255,255,.2); color: #fff; }

/* Prefs panel */
.aris-prefs-panel {
  background: #f0f3f7; border-bottom: 1px solid #e2e8f0;
  padding: .75rem 1rem; flex-shrink: 0;
  max-height: 0; overflow: hidden;
  transition: max-height .25s cubic-bezier(.4,0,.2,1), padding .25s;
}
.aris-prefs-panel.is-open { max-height: 200px; }
.aris-prefs-title {
  font-size: .73rem; font-weight: 700; color: #1e293b; margin: 0 0 .5rem;
}
.aris-prefs-fields { display: flex; gap: .5rem; margin-bottom: .5rem; }
.aris-prefs-label {
  display: flex; flex-direction: column; gap: .2rem;
  font-size: .67rem; color: #475569; font-weight: 600; flex: 1;
}
.aris-prefs-input, .aris-prefs-select {
  border: 1px solid #cbd5e1; border-radius: .5rem;
  padding: .3rem .5rem; font-size: .72rem; color: #1e293b;
  background: #fff; outline: none;
  transition: border-color .15s;
}
.aris-prefs-input:focus, .aris-prefs-select:focus { border-color: #003c78; }
.aris-prefs-footer { display: flex; align-items: center; gap: .5rem; }
.aris-prefs-save-btn {
  background: #003c78; color: #fff; border: none;
  border-radius: .5rem; padding: .3rem .75rem;
  font-size: .72rem; font-weight: 700; cursor: pointer;
  transition: background .15s;
}
.aris-prefs-save-btn:hover { background: #002448; }
.aris-icon-btn-sm {
  background: none; border: 1px solid #cbd5e1; border-radius: .5rem;
  padding: .3rem .6rem; font-size: .7rem; color: #64748b; cursor: pointer;
  transition: background .15s;
}
.aris-icon-btn-sm:hover { background: #e2e8f0; }

/* Messages */
.aris-messages {
  flex: 1; overflow-y: auto; padding: 1rem;
  display: flex; flex-direction: column; gap: .7rem;
  scroll-behavior: smooth;
}
.aris-messages::-webkit-scrollbar { width: 4px; }
.aris-messages::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 2px; }

/* Restored notice */
.aris-restored-bar {
  display: flex; align-items: center; justify-content: space-between;
  gap: .5rem; padding: .4rem .65rem;
  background: #f0f3f7; border-radius: .65rem;
  border: 1px solid #e2e8f0;
  font-size: .68rem; color: #64748b; flex-shrink: 0;
}
.aris-restore-clear {
  background: none; border: none; color: #003c78; cursor: pointer;
  font-size: .68rem; font-weight: 600; padding: 0; white-space: nowrap;
  text-decoration: underline;
}
.aris-restore-clear:hover { color: #002448; }

/* Welcome */
#aris-welcome {
  display: flex; flex-direction: column; align-items: center;
  text-align: center; gap: .45rem; padding: .75rem 0;
}
.aris-welcome-icon {
  width: 96px; height: 96px; border-radius: 50%;
  background: linear-gradient(135deg,#003c78,#009c78);
  display: flex; align-items: center; justify-content: center;
  color: #fff; margin-bottom: .2rem; overflow: hidden;
}
.aris-face-img {
  width: 100%; height: 100%; object-fit: cover; border-radius: 9999px; display: block;
}
.aris-fab-face {
  width: 48px; height: 48px; border-radius: 9999px;
  overflow: hidden; flex-shrink: 0;
  background: rgba(255,255,255,.15);
  display: flex; align-items: center; justify-content: center;
}
.aris-welcome-title {
  font-family: 'Space Grotesk', system-ui, sans-serif;
  font-size: 1rem; font-weight: 600; color: #1e293b; margin: 0;
}
.aris-welcome-sub { font-size: .78rem; color: #64748b; margin: 0; line-height: 1.55; }
.aris-chips {
  display: flex; flex-wrap: wrap; gap: .35rem; justify-content: center; margin-top: .4rem;
}
.aris-chip {
  background: #f0f3f7; border: 1px solid #e2e8f0; border-radius: 9999px;
  padding: .28rem .75rem; font-size: .7rem; font-weight: 500;
  color: #003c78; cursor: pointer;
  transition: background .15s, border-color .15s;
}
.aris-chip:hover { background: #dee6ed; border-color: #8ca7c2; }

/* Bubble wrapper */
.aris-msg {
  display: flex; flex-direction: column; max-width: 90%;
  animation: arisFadeIn .2s ease;
}
.aris-msg-user { align-self: flex-end; align-items: flex-end; }
.aris-msg-bot  { align-self: flex-start; align-items: flex-start; }

/* Bubbles */
.aris-bubble {
  padding: .55rem .85rem;
  border-radius: 1.1rem;
  font-size: .8rem; line-height: 1.6; word-break: break-word;
}
.aris-bubble-user {
  background: #003c78; color: #fff;
  border-bottom-right-radius: .25rem;
}
.aris-bubble-bot {
  background: #f8fafc; color: #1e293b;
  border: 1px solid #e2e8f0;
  border-bottom-left-radius: .25rem;
}
.aris-bubble-bot strong { color: #003c78; }
.aris-bubble-bot ul { padding-left: 1.2em; margin: .25em 0; }
.aris-bubble-bot li { margin-bottom: .15em; }
.aris-bubble-bot em { font-style: italic; }

/* Loading dots */
.aris-loading {
  align-self: flex-start;
  display: flex; align-items: center; gap: .22rem;
  padding: .55rem .85rem;
  background: #f8fafc; border: 1px solid #e2e8f0;
  border-radius: 1.1rem; border-bottom-left-radius: .25rem;
}
.aris-dot {
  width: 5px; height: 5px; border-radius: 50%;
  background: #94a3b8; animation: arisDot 1.1s infinite;
}
.aris-dot:nth-child(2) { animation-delay: .18s; }
.aris-dot:nth-child(3) { animation-delay: .36s; }

/* Meta / sources */
.aris-meta { margin-top: .35rem; }
.aris-badge {
  display: inline-flex; align-items: center; gap: .25rem;
  font-size: .66rem; font-weight: 600; padding: .18rem .55rem;
  border-radius: 9999px; margin-bottom: .3rem;
}
.aris-badge-alta  { background: #def2ed; color: #007d60; }
.aris-badge-media { background: #fefce8; color: #92400e; }
.aris-badge-non_trovata { background: #fee2e2; color: #991b1b; }
.aris-sources {
  font-size: .68rem; color: #64748b;
  background: #f8fafc; border: 1px solid #e2e8f0;
  border-radius: .75rem; padding: .45rem .65rem;
  margin-bottom: .3rem;
}
.aris-sources-title { font-weight: 600; color: #475569; margin-bottom: .2rem; display: block; }
.aris-source-link {
  display: block; color: #003c78; text-decoration: none;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  line-height: 1.6;
}
.aris-source-link:hover { text-decoration: underline; }

/* Navigation action buttons */
.aris-actions {
  display: flex; flex-wrap: wrap; gap: .3rem; margin-top: .35rem;
}
.aris-action-btn {
  display: inline-flex; align-items: center; gap: .3rem;
  background: #fff; border: 1px solid #003c78; border-radius: .6rem;
  padding: .28rem .65rem; font-size: .71rem; font-weight: 600;
  color: #003c78; cursor: pointer;
  transition: background .15s, color .15s, transform .1s;
  white-space: nowrap;
}
.aris-action-btn:hover { background: #003c78; color: #fff; transform: translateY(-1px); }
.aris-action-btn:active { transform: none; }
.aris-action-btn-ext {
  border-color: #475569; color: #475569;
}
.aris-action-btn-ext:hover { background: #475569; color: #fff; }
.aris-action-copy { border-color: #059669; color: #059669; }
.aris-action-copy:hover { background: #059669; color: #fff; }

/* Feedback */
.aris-feedback {
  display: flex; align-items: center; gap: .35rem;
  margin-top: .3rem;
}
.aris-feedback-label { font-size: .66rem; color: #94a3b8; }
.aris-fb-btn {
  background: none; border: 1px solid #e2e8f0; border-radius: 6px;
  padding: .15rem .45rem; font-size: .72rem; cursor: pointer;
  color: #64748b; transition: background .15s, border-color .15s, color .15s;
  line-height: 1;
}
.aris-fb-btn:hover  { background: #f0f3f7; border-color: #94a3b8; color: #1e293b; }
.aris-fb-btn.voted  { border-color: #009c78; color: #007d60; background: #def2ed; cursor: default; }
.aris-feedback-thanks { font-size: .66rem; color: #007d60; }

/* Input */
.aris-input-area {
  display: flex; align-items: flex-end; gap: .45rem;
  padding: .55rem .7rem;
  border-top: 1px solid #e2e8f0; background: #fff; flex-shrink: 0;
}
.aris-textarea {
  flex: 1; resize: none; border: 1px solid #e2e8f0; border-radius: .875rem;
  padding: .45rem .7rem;
  font-family: 'Inter Variable', Inter, system-ui, sans-serif;
  font-size: .8rem; line-height: 1.5; color: #1e293b;
  max-height: 110px; overflow-y: auto; outline: none;
  transition: border-color .15s;
}
.aris-textarea:focus { border-color: #003c78; }
.aris-textarea::placeholder { color: #94a3b8; }
.aris-send-btn {
  width: 34px; height: 34px; border-radius: 50%;
  background: #003c78; color: #fff; border: none;
  cursor: pointer; display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; transition: background .15s, transform .15s;
}
.aris-send-btn:hover:not(:disabled) { background: #002448; transform: scale(1.05); }
.aris-send-btn:disabled { background: #94a3b8; cursor: not-allowed; transform: none; }
.aris-foot-note {
  text-align: center; font-size: .6rem; color: #94a3b8;
  padding: .25rem 1rem .45rem; margin: 0; flex-shrink: 0;
}

/* Animations */
@keyframes arisFadeIn {
  from { opacity: 0; transform: translateY(4px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes arisDot {
  0%,80%,100% { opacity: .3; transform: scale(.8); }
  40% { opacity: 1; transform: scale(1); }
}
@media (prefers-reduced-motion: reduce) {
  .aris-fab { transition: none; }
  .aris-panel { transition: none; }
  .aris-msg  { animation: none; }
  .aris-dot  { animation: none; opacity: .5; }
}
</style>

<script>
(function () {
  // ── Elements ──────────────────────────────────────────
  const fabEl      = document.getElementById('aris-fab')          as HTMLButtonElement | null;
  const panelEl    = document.getElementById('aris-panel')        as HTMLElement | null;
  const msgsEl     = document.getElementById('aris-messages')     as HTMLElement | null;
  const textareaEl = document.getElementById('aris-textarea')     as HTMLTextAreaElement | null;
  const sendBtnEl  = document.getElementById('aris-send')         as HTMLButtonElement | null;
  const prefsPanelEl = document.getElementById('aris-prefs-panel') as HTMLElement | null;

  if (!fabEl || !panelEl || !msgsEl || !textareaEl || !sendBtnEl) return;

  const fab        = fabEl;
  const panel      = panelEl;
  const msgs       = msgsEl;
  const textarea   = textareaEl;
  const sendBtn    = sendBtnEl;
  const prefsPanel = prefsPanelEl;

  const closeBtn    = document.getElementById('aris-close')      as HTMLButtonElement | null;
  const resetBtn    = document.getElementById('aris-reset')      as HTMLButtonElement | null;
  const prefsBtnEl  = document.getElementById('aris-prefs-btn')  as HTMLButtonElement | null;
  const prefsSaveEl = document.getElementById('aris-prefs-save') as HTMLButtonElement | null;
  const prefsClose  = document.getElementById('aris-prefs-close') as HTMLButtonElement | null;
  const welcome     = document.getElementById('aris-welcome')    as HTMLElement | null;
  const subtitleEl  = document.getElementById('aris-subtitle-txt') as HTMLElement | null;

  const prefsCorsoEl = document.getElementById('aris-pref-corso') as HTMLInputElement | null;
  const prefsAnnoEl  = document.getElementById('aris-pref-anno')  as HTMLSelectElement | null;

  // ── Types ─────────────────────────────────────────────
  interface Source { titolo: string; url: string | null; source: string; }
  interface NavigationAction {
    type:     string;
    label:    string;
    url?:     string;
    filters?: Record<string, string>;
    query?:   string;
    value?:   string;
  }
  interface StoredMsg {
    role:         'user' | 'bot';
    content:      string;
    sources?:     Source[];
    affidabilita?: string;
  }
  interface ArisPrefs { corso: string; anno: string; }

  // ── State ─────────────────────────────────────────────
  let isOpen    = false;
  let isLoading = false;
  let history: Array<{ role: 'user' | 'assistant'; content: string }> = [];
  let displayMessages: StoredMsg[] = [];
  const feedbackData = new Map<string, { question: string; answer: string; sources: Source[] }>();
  let prefs: ArisPrefs = { corso: '', anno: '' };

  // ── localStorage ──────────────────────────────────────
  const STORAGE_KEY  = 'aris-conv-v1';
  const PREFS_KEY    = 'aris-prefs-v1';
  const MAX_MESSAGES = 40;
  const TTL_MS       = 24 * 60 * 60 * 1000;

  function saveToStorage(): void {
    if (displayMessages.length === 0) return;
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify({
        messages: displayMessages.slice(-MAX_MESSAGES),
        history:  history.slice(-MAX_MESSAGES),
        savedAt:  Date.now(),
      }));
    } catch { /* quota exceeded */ }
  }

  function clearStorage(): void {
    try { localStorage.removeItem(STORAGE_KEY); } catch { /* noop */ }
  }

  function loadFromStorage(): { messages: StoredMsg[]; history: typeof history } | null {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return null;
      const data = JSON.parse(raw) as { messages: StoredMsg[]; history: typeof history; savedAt: number };
      if (Date.now() - data.savedAt > TTL_MS) { clearStorage(); return null; }
      if (!Array.isArray(data.messages) || data.messages.length === 0) return null;
      return data;
    } catch { return null; }
  }

  function savePrefs(): void {
    try { localStorage.setItem(PREFS_KEY, JSON.stringify(prefs)); } catch { /* noop */ }
  }

  function loadPrefs(): void {
    try {
      const raw = localStorage.getItem(PREFS_KEY);
      if (!raw) return;
      const p = JSON.parse(raw) as Partial<ArisPrefs>;
      prefs.corso = p.corso ?? '';
      prefs.anno  = p.anno  ?? '';
    } catch { /* noop */ }
    if (prefsCorsoEl) prefsCorsoEl.value = prefs.corso;
    if (prefsAnnoEl)  prefsAnnoEl.value  = prefs.anno;
    updateSubtitle();
  }

  function updateSubtitle(): void {
    if (!subtitleEl) return;
    if (prefs.corso || prefs.anno) {
      subtitleEl.textContent = [prefs.corso, prefs.anno].filter(Boolean).join(' · ');
    } else {
      subtitleEl.textContent = 'Assistente di Area Nuova';
    }
  }

  // ── Prefs panel ───────────────────────────────────────
  let prefsOpen = false;

  function openPrefs(): void {
    prefsOpen = true;
    prefsPanel?.classList.add('is-open');
    prefsPanel?.setAttribute('aria-hidden', 'false');
    prefsBtnEl?.classList.add('is-active');
    prefsCorsoEl?.focus();
  }

  function closePrefs(): void {
    prefsOpen = false;
    prefsPanel?.classList.remove('is-open');
    prefsPanel?.setAttribute('aria-hidden', 'true');
    prefsBtnEl?.classList.remove('is-active');
  }

  prefsBtnEl?.addEventListener('click', () => (prefsOpen ? closePrefs() : openPrefs()));
  prefsClose?.addEventListener('click', closePrefs);

  prefsSaveEl?.addEventListener('click', () => {
    prefs.corso = prefsCorsoEl?.value.trim() ?? '';
    prefs.anno  = prefsAnnoEl?.value ?? '';
    savePrefs();
    updateSubtitle();
    closePrefs();
  });

  // ── Open / Close panel ────────────────────────────────
  function open(): void {
    isOpen = true;
    panel.classList.add('is-open');
    fab.setAttribute('aria-expanded', 'true');
    panel.setAttribute('aria-hidden', 'false');
    textarea.focus();
  }

  function close(): void {
    isOpen = false;
    panel.classList.remove('is-open');
    fab.setAttribute('aria-expanded', 'false');
    panel.setAttribute('aria-hidden', 'true');
    closePrefs();
  }

  function resetUI(): void {
    while (msgs.firstChild) msgs.removeChild(msgs.firstChild);
    if (welcome) {
      const fresh = welcome.cloneNode(true) as HTMLElement;
      fresh.style.display = '';
      msgs.appendChild(fresh);
      fresh.querySelectorAll<HTMLButtonElement>('.aris-chip').forEach((c) => {
        c.addEventListener('click', onChip);
      });
    }
    history         = [];
    displayMessages = [];
    feedbackData.clear();
  }

  function reset(): void {
    clearStorage();
    resetUI();
  }

  fab.addEventListener('click', () => (isOpen ? close() : open()));
  closeBtn?.addEventListener('click', close);
  resetBtn?.addEventListener('click', reset);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && isOpen) close(); });

  // ── Chips ─────────────────────────────────────────────
  function onChip(e: Event): void {
    const q = (e.currentTarget as HTMLButtonElement).dataset.q;
    if (q) void sendMessage(q);
  }
  document.querySelectorAll<HTMLButtonElement>('.aris-chip').forEach((c) =>
    c.addEventListener('click', onChip),
  );

  // ── Textarea auto-resize ──────────────────────────────
  textarea.addEventListener('input', () => {
    textarea.style.height = 'auto';
    textarea.style.height = Math.min(textarea.scrollHeight, 110) + 'px';
    sendBtn.disabled = !textarea.value.trim() || isLoading;
  });

  textarea.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      if (!sendBtn.disabled) sendBtn.click();
    }
  });

  sendBtn.addEventListener('click', () => {
    const v = textarea.value.trim();
    if (!v || isLoading) return;
    textarea.value = '';
    textarea.style.height = 'auto';
    sendBtn.disabled = true;
    void sendMessage(v);
  });

  // ── Scroll ────────────────────────────────────────────
  function scrollBottom(): void { msgs.scrollTop = msgs.scrollHeight; }

  // ── Hide welcome ──────────────────────────────────────
  function hideWelcome(): void {
    const w = msgs.querySelector<HTMLElement>('#aris-welcome');
    if (w) w.style.display = 'none';
  }

  // ── Unique ID ─────────────────────────────────────────
  function generateId(): string { return crypto.randomUUID(); }

  // ── Render user bubble ────────────────────────────────
  function addUser(text: string): void {
    hideWelcome();
    const wrap = document.createElement('div');
    wrap.className = 'aris-msg aris-msg-user';
    const b = document.createElement('div');
    b.className = 'aris-bubble aris-bubble-user';
    b.textContent = text;
    wrap.appendChild(b);
    msgs.appendChild(wrap);
    scrollBottom();
  }

  // ── Loading dots ──────────────────────────────────────
  function addLoading(): HTMLElement {
    const el = document.createElement('div');
    el.className = 'aris-loading';
    el.setAttribute('aria-label', 'Aris sta cercando…');
    for (let i = 0; i < 3; i++) {
      const d = document.createElement('div');
      d.className = 'aris-dot';
      el.appendChild(d);
    }
    msgs.appendChild(el);
    scrollBottom();
    return el;
  }

  // ── Minimal markdown → HTML ───────────────────────────
  function md(raw: string): string {
    return raw
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
      .replace(/\*(.+?)\*/g, '<em>$1</em>')
      .replace(/\[([^\]]+)\]\(([^)]+)\)/g, (_m, text, url) => {
        const u = url.trim();
        return /^https?:\/\//i.test(u) || u.startsWith('/')
          ? `<a href="${u}" target="_blank" rel="noopener noreferrer">${text}</a>`
          : text;
      })
      .replace(/^#{1,4} (.+)$/gm, '<strong>$1</strong>')
      .replace(/^[-*] (.+)$/gm, '<li>$1</li>')
      .replace(/(<li>[\s\S]+?<\/li>)/g, '<ul>$1</ul>')
      .replace(/\n\n/g, '<br><br>')
      .replace(/\n(?!<)/g, '<br>');
  }

  // ── Navigation action click ───────────────────────────
  function handleActionClick(action: NavigationAction): void {
    switch (action.type) {
      case 'navigate':
      case 'open-page':
        if (action.url) window.location.href = action.url;
        break;
      case 'external-link':
        if (action.url) window.open(action.url, '_blank', 'noopener,noreferrer');
        break;
      case 'open-filter': {
        if (!action.url) break;
        const params = new URLSearchParams(action.filters ?? {});
        window.location.href = `${action.url}?${params.toString()}`;
        break;
      }
      case 'search': {
        if (!action.url) break;
        const q = encodeURIComponent(action.query ?? '');
        window.location.href = `${action.url}?q=${q}`;
        break;
      }
      case 'copy':
        if (action.value) {
          navigator.clipboard.writeText(action.value).catch(() => { /* clipboard not available */ });
        }
        break;
    }
  }

  // ── Render action buttons ─────────────────────────────
  function renderActions(actions: NavigationAction[]): HTMLElement | null {
    if (!actions || actions.length === 0) return null;
    const container = document.createElement('div');
    container.className = 'aris-actions';
    actions.forEach((action) => {
      const btn = document.createElement('button');
      const isExt  = action.type === 'external-link';
      const isCopy = action.type === 'copy';
      btn.className = `aris-action-btn${isExt ? ' aris-action-btn-ext' : ''}${isCopy ? ' aris-action-copy' : ''}`;
      btn.textContent = (isExt ? '↗ ' : isCopy ? '📋 ' : '→ ') + action.label;
      btn.setAttribute('aria-label', action.label);
      btn.addEventListener('click', () => handleActionClick(action));
      container.appendChild(btn);
    });
    return container;
  }

  // ── Feedback ──────────────────────────────────────────
  async function sendFeedback(responseId: string, rating: number, btn: HTMLElement): Promise<void> {
    const data = feedbackData.get(responseId);
    if (!data) return;
    const container = btn.closest('.aris-feedback');
    if (!container) return;
    try {
      await fetch('/api/aris/feedback', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          response_id: responseId,
          question:    data.question,
          answer:      data.answer,
          rating,
          sources:     data.sources,
          page_url:    window.location.href,
        }),
      });
    } catch { /* non bloccare la UI */ }
    container.innerHTML = '<span class="aris-feedback-thanks">Grazie per il feedback!</span>';
  }

  // ── Render bot message ────────────────────────────────
  function addBot(
    text: string,
    sources: Source[],
    affidabilita: string,
    actions: NavigationAction[] = [],
    responseId: string | null = null,
    isRestored = false,
  ): void {
    const wrap = document.createElement('div');
    wrap.className = 'aris-msg aris-msg-bot';

    const b = document.createElement('div');
    b.className = 'aris-bubble aris-bubble-bot';
    b.innerHTML = md(text);
    wrap.appendChild(b);

    if (affidabilita) {
      const meta = document.createElement('div');
      meta.className = 'aris-meta';

      const badge = document.createElement('span');
      badge.className = `aris-badge aris-badge-${affidabilita}`;
      badge.textContent =
        affidabilita === 'alta'   ? '✓ Alta affidabilità'    :
        affidabilita === 'media'  ? '~ Media affidabilità'   :
                                    '✗ Informazione non trovata';
      meta.appendChild(badge);

      if (sources.length > 0) {
        const src = document.createElement('div');
        src.className = 'aris-sources';
        const title = document.createElement('span');
        title.className = 'aris-sources-title';
        title.textContent = 'Fonti consultate';
        src.appendChild(title);
        sources.forEach((s) => {
          const a = document.createElement('a');
          a.className = 'aris-source-link';
          a.textContent = '• ' + s.titolo;
          if (s.url) { a.href = s.url; a.target = '_blank'; a.rel = 'noopener noreferrer'; }
          src.appendChild(a);
        });
        meta.appendChild(src);
      }

      // Action buttons
      if (actions.length > 0) {
        const actionsEl = renderActions(actions);
        if (actionsEl) meta.appendChild(actionsEl);
      }

      // Feedback buttons (solo messaggi nuovi)
      if (!isRestored && responseId) {
        const fb = document.createElement('div');
        fb.className = 'aris-feedback';
        fb.setAttribute('aria-label', 'Valuta questa risposta');
        const lbl = document.createElement('span');
        lbl.className = 'aris-feedback-label';
        lbl.textContent = 'Utile?';
        fb.appendChild(lbl);
        [{ emoji: '👍', rating: 1, label: 'Sì, risposta utile' },
         { emoji: '👎', rating: -1, label: 'No, risposta non utile' }].forEach(({ emoji, rating, label }) => {
          const btn = document.createElement('button');
          btn.className = 'aris-fb-btn';
          btn.textContent = emoji;
          btn.setAttribute('aria-label', label);
          btn.addEventListener('click', async () => {
            if (btn.classList.contains('voted')) return;
            btn.classList.add('voted');
            fb.querySelectorAll<HTMLButtonElement>('.aris-fb-btn').forEach((b2) => {
              b2.disabled = true;
              if (b2 !== btn) b2.style.opacity = '.3';
            });
            await sendFeedback(responseId, rating, btn);
          });
          fb.appendChild(btn);
        });
        meta.appendChild(fb);
      }

      wrap.appendChild(meta);
    }

    msgs.appendChild(wrap);
    scrollBottom();
  }

  // ── Ripristino da localStorage ────────────────────────
  function initFromStorage(): void {
    const stored = loadFromStorage();
    if (!stored || stored.messages.length === 0) return;

    const bar = document.createElement('div');
    bar.className = 'aris-restored-bar';
    bar.innerHTML = '<span>Conversazione precedente ripristinata</span>';
    const clearBtn = document.createElement('button');
    clearBtn.className = 'aris-restore-clear';
    clearBtn.textContent = 'Inizia nuova';
    clearBtn.addEventListener('click', reset);
    bar.appendChild(clearBtn);

    hideWelcome();
    msgs.appendChild(bar);

    stored.messages.forEach((m) => {
      if (m.role === 'user') {
        addUser(m.content);
      } else {
        addBot(m.content, m.sources ?? [], m.affidabilita ?? '', [], null, true);
      }
    });

    history         = stored.history ?? [];
    displayMessages = stored.messages;
  }

  // ── Build context string for API ──────────────────────
  function buildContext(): string | undefined {
    const parts: string[] = [];
    if (prefs.corso) parts.push(`Corso: ${prefs.corso}`);
    if (prefs.anno)  parts.push(`Anno: ${prefs.anno}`);
    return parts.length > 0 ? parts.join(', ') : undefined;
  }

  // ── Send & stream ─────────────────────────────────────
  async function sendMessage(text: string): Promise<void> {
    if (isLoading) return;
    isLoading = true;
    sendBtn.disabled = true;

    addUser(text);
    displayMessages.push({ role: 'user', content: text });

    const loading = addLoading();

    let full                     = '';
    let sources: Source[]        = [];
    let affidabilita             = '';
    let actions: NavigationAction[] = [];
    let streamWrap: HTMLElement | null   = null;
    let streamBubble: HTMLElement | null = null;

    try {
      const body: Record<string, unknown> = { message: text, history };
      const ctx = buildContext();
      if (ctx) body.context = ctx;

      const res = await fetch('/api/chat', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify(body),
      });

      if (!res.ok) {
        const j = await res.json().catch(() => ({ error: `HTTP ${res.status}` }));
        throw new Error((j as { error: string }).error ?? `HTTP ${res.status}`);
      }

      const reader  = res.body!.getReader();
      const decoder = new TextDecoder();
      let   buffer  = '';

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;

        buffer += decoder.decode(value, { stream: true });
        const lines = buffer.split('\n');
        buffer = lines.pop() ?? '';

        for (const line of lines) {
          if (!line.startsWith('data: ')) continue;
          const raw = line.slice(6).trim();
          if (raw === '[DONE]') { reader.cancel(); break; }

          type SseEvt = {
            type:          string;
            content?:      string;
            sources?:      Source[];
            affidabilita?: string;
            message?:      string;
            actions?:      NavigationAction[];
          };
          let evt: SseEvt | null = null;
          try { evt = JSON.parse(raw) as SseEvt; } catch { continue; }
          if (!evt) continue;

          if (evt.type === 'chunk' && evt.content) {
            if (!streamWrap) {
              loading.remove();
              streamWrap   = document.createElement('div');
              streamWrap.className = 'aris-msg aris-msg-bot';
              streamBubble = document.createElement('div');
              streamBubble.className = 'aris-bubble aris-bubble-bot';
              streamWrap.appendChild(streamBubble);
              msgs.appendChild(streamWrap);
            }
            full += evt.content;
            if (streamBubble) streamBubble.innerHTML = md(full);
            scrollBottom();
          } else if (evt.type === 'meta') {
            sources      = evt.sources      ?? [];
            affidabilita = evt.affidabilita ?? '';
            actions      = evt.actions      ?? [];
          } else if (evt.type === 'error') {
            throw new Error(evt.message ?? 'Errore sconosciuto');
          }
        }
      }

      if (streamWrap && full) {
        streamWrap.remove();
        const responseId = generateId();
        feedbackData.set(responseId, { question: text, answer: full, sources });
        addBot(full, sources, affidabilita, actions, responseId, false);

        history.push({ role: 'user', content: text });
        history.push({ role: 'assistant', content: full });
        if (history.length > 20) history = history.slice(-20);

        displayMessages.push({ role: 'bot', content: full, sources, affidabilita });
        if (displayMessages.length > MAX_MESSAGES) displayMessages = displayMessages.slice(-MAX_MESSAGES);

        saveToStorage();
      } else {
        loading.remove();
        addBot('Non ho ricevuto una risposta. Riprova tra qualche istante.', [], '', [], null, false);
      }

    } catch (err) {
      loading.remove();
      streamWrap?.remove();
      const errMsg = err instanceof Error ? err.message : 'Errore di rete.';
      addBot(errMsg, [], '', [], null, false);
    } finally {
      isLoading = false;
      sendBtn.disabled = !textarea.value.trim();
    }
  }

  // ── Init ──────────────────────────────────────────────
  loadPrefs();
  initFromStorage();
})();
</script>
