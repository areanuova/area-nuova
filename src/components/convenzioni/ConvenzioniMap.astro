---
/**
 * Mappa interattiva Leaflet + OpenStreetMap delle convenzioni Area Nuova.
 * Le coordinate vengono passate come prop già pre-calcolate (niente geocoding runtime).
 * La mappa si inizializza interamente client-side: nessun problema SSR/build statica.
 */

export interface ConvenzionePoint {
  nome: string;
  nomeSede?: string;
  categoria: string;
  tipo: string;
  citta: string;
  indirizzo: string;
  offerta: string;
  lat: number;
  lng: number;
}

interface Props {
  punti: ConvenzionePoint[];
}

const { punti } = Astro.props;
const puntiJson = JSON.stringify(punti);
---

{punti.length === 0 ? (
  <p class="text-sm text-slate-500">Nessuna convenzione con indirizzo verificabile disponibile.</p>
) : (
  <div class="overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-slate-200">
    <div id="mappa-convenzioni" style="height:420px;z-index:0;" aria-label="Mappa delle convenzioni Area Nuova"></div>
  </div>
  <p class="mt-3 text-center text-xs text-slate-400">
    La mappa mostra solo le convenzioni per cui è disponibile un indirizzo verificabile.
    &nbsp;·&nbsp; <strong class="text-slate-500">{punti.length}</strong> convenzioni mappate.
  </p>
)}

<!-- Bridge dati server → client (nascosto) -->
<div id="mappa-punti-data" data-punti={puntiJson} style="display:none;" aria-hidden="true"></div>

<script>
  import 'leaflet/dist/leaflet.css';
  import L from 'leaflet';

  // Recupera i dati dal DOM
  const dataEl = document.getElementById('mappa-punti-data');
  if (!dataEl) throw new Error('[ConvenzioniMap] elemento dati non trovato');

  const punti = JSON.parse(dataEl.dataset.punti ?? '[]');

  if (punti.length > 0) {

  // ── Mappa base ──────────────────────────────────────────────────────────────
  const FOGGIA: [number, number] = [41.462, 15.549];

  const map = L.map('mappa-convenzioni', {
    center: FOGGIA,
    zoom: 14,
    scrollWheelZoom: false,
    zoomControl: true,
  });

  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution:
      '&copy; <a href="https://www.openstreetmap.org/copyright" target="_blank" rel="noopener">OpenStreetMap</a> contributors',
    maxZoom: 19,
  }).addTo(map);

  // ── Palette colori per tipo ─────────────────────────────────────────────────
  // Coerenti con il design system Tailwind del sito
  const MARKER_COLOR = {
    'main-sponsor':       '#009c78', // accent-700
    'exclusive':          '#003c78', // primary-700
    'standard':           '#475569', // slate-600
    'nuove-convenzioni':  '#d97706', // amber-600
  };
  const BADGE_BG = {
    'main-sponsor':       '#def2ed', // accent-100
    'exclusive':          '#dee6ed', // primary-100
    'standard':           '#f1f5f9', // slate-100
    'nuove-convenzioni':  '#fef3c7', // amber-100
  };
  const BADGE_TEXT = {
    'main-sponsor':       '#007d60', // accent-800
    'exclusive':          '#003060', // primary-800
    'standard':           '#334155', // slate-700
    'nuove-convenzioni':  '#92400e', // amber-800
  };
  const TIPO_LABEL = {
    'main-sponsor':       'Main Sponsor',
    'exclusive':          'Exclusive',
    'standard':           'Standard',
    'nuove-convenzioni':  'Nuove Convenzioni',
  };

  // ── Marker SVG inline (evita il bug Vite con le immagini di Leaflet) ────────
  function makeIcon(tipo: string) {
    const color = (MARKER_COLOR as Record<string, string>)[tipo] ?? '#475569';
    const svg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 28 40" width="28" height="40">
      <path d="M14 0C6.3 0 0 6.3 0 14c0 9.1 14 26 14 26S28 23.1 28 14C28 6.3 21.7 0 14 0z"
            fill="${color}" stroke="rgba(255,255,255,0.8)" stroke-width="1.5"/>
      <circle cx="14" cy="14" r="6" fill="white"/>
    </svg>`;
    return L.divIcon({
      html: svg,
      className: '',
      iconSize: [28, 40],
      iconAnchor: [14, 40],
      popupAnchor: [0, -42],
    });
  }

  // ── Popup HTML ──────────────────────────────────────────────────────────────
  function makePopup(p: Record<string, any>) {
    const bg   = (BADGE_BG as Record<string, string>)[p.tipo]    ?? '#f1f5f9';
    const text = (BADGE_TEXT as Record<string, string>)[p.tipo]  ?? '#334155';
    const label = (TIPO_LABEL as Record<string, string>)[p.tipo] ?? p.tipo;

    return `
      <div style="min-width:200px;max-width:260px;font-family:system-ui,sans-serif;line-height:1.4;">
        <div style="display:flex;flex-wrap:wrap;gap:4px;margin-bottom:8px;">
          <span style="background:${bg};color:${text};border-radius:9999px;padding:2px 9px;
                       font-size:11px;font-weight:700;">${label}</span>
          <span style="background:#f1f5f9;color:#475569;border-radius:9999px;padding:2px 9px;
                       font-size:11px;font-weight:500;">${p.citta}</span>
        </div>
        <h3 style="margin:0 0 2px;font-size:14px;font-weight:700;color:#0f172a;">${p.nome}</h3>
        <p  style="margin:0 0 7px;font-size:12px;color:#64748b;">${p.categoria}</p>
        ${p.nomeSede
          ? `<p style="margin:0 0 8px;font-size:12px;color:#475569;display:flex;gap:5px;align-items:flex-start;">
               <span>📍</span><span><strong>${p.nomeSede}</strong>${p.indirizzo ? ` · ${p.indirizzo}` : ''}</span>
             </p>`
          : p.indirizzo
          ? `<p style="margin:0 0 8px;font-size:12px;color:#475569;display:flex;gap:5px;align-items:flex-start;">
               <span>📍</span><span>${p.indirizzo}</span>
             </p>`
          : ''}
        ${p.offerta
          ? `<p style="margin:0;font-size:12px;background:#f0fdf4;color:#166534;
                       border-radius:6px;padding:5px 9px;">✓ ${p.offerta}</p>`
          : ''}
      </div>`;
  }

  // ── Offset radiale per marker sovrapposti ───────────────────────────────────
  // Raggruppa i punti per coordinate arrotondate a 4 decimali (~11m di precisione).
  // Per ogni gruppo con più elementi applica un offset circolare proporzionale,
  // così i marker restano cliccabili separatamente senza inventare coordinate.
  const OVERLAP_RADIUS = 0.00023; // ≈ 25 m in latitudine
  const groups = new Map();
  for (const p of punti) {
    const key = `${p.lat.toFixed(4)},${p.lng.toFixed(4)}`;
    if (!groups.has(key)) groups.set(key, []);
    groups.get(key).push(p);
  }

  const plotPoints = [];
  for (const group of groups.values()) {
    if (group.length === 1) {
      plotPoints.push({ ...group[0], plotLat: group[0].lat, plotLng: group[0].lng });
    } else {
      const latRad = group[0].lat * (Math.PI / 180);
      const lngScale = 1 / Math.cos(latRad); // corregge la distorsione longitudine
      const n = group.length;
      group.forEach((p: Record<string, any>, i: number) => {
        const angle = (2 * Math.PI * i) / n - Math.PI / 2; // parte dall'alto
        plotPoints.push({
          ...p,
          plotLat: p.lat + OVERLAP_RADIUS * Math.cos(angle),
          plotLng: p.lng + OVERLAP_RADIUS * lngScale * Math.sin(angle),
        });
      });
    }
  }

  // ── Aggiunta marker ─────────────────────────────────────────────────────────
  for (const p of plotPoints) {
    L.marker([p.plotLat, p.plotLng], { icon: makeIcon(p.tipo) })
      .bindPopup(makePopup(p), { maxWidth: 280 })
      .addTo(map);
  }

  // Adatta lo zoom per includere tutti i marker (usa le coordinate reali, non plot)
  if (punti.length > 1) {
    const bounds = L.latLngBounds(punti.map((p: { lat: number; lng: number }) => [p.lat, p.lng]));
    map.fitBounds(bounds, { padding: [40, 40], maxZoom: 15 });
  }

  } // fine if (punti.length > 0)
</script>

<style is:global>
  /* Stile Leaflet popup personalizzato */
  .leaflet-popup-content-wrapper {
    border-radius: 12px !important;
    box-shadow: 0 4px 24px rgba(0,0,0,0.12) !important;
    padding: 0 !important;
  }
  .leaflet-popup-content {
    margin: 14px 16px !important;
  }
  .leaflet-popup-tip-container {
    margin-top: -1px;
  }

  /* Altezza responsive */
  @media (max-width: 640px) {
    #mappa-convenzioni {
      height: 320px !important;
    }
  }
</style>
