---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SicurezzaBadge from '../../components/alloggi/SicurezzaBadge.astro';
import DisclaimerBox from '../../components/alloggi/DisclaimerBox.astro';
import { supabase } from '../../lib/supabase';

type Annuncio = {
  id: string;
  titolo: string;
  tipo: string;
  citta: string;
  zona: string | null;
  prezzo: number;
  spese_incluse: boolean;
  disponibile_da: string | null;
  descrizione: string;
  foto_url: string | null;
  foto_urls: unknown;
  inserzionista_nome: string;
  inserzionista_email: string;
  inserzionista_telefono: string | null;
  scade_il: string | null;
};

const TIPO_LABEL: Record<string, string> = {
  stanza_singola: 'Stanza singola',
  stanza_doppia: 'Stanza doppia',
  posto_letto: 'Posto letto',
  monolocale: 'Monolocale',
  bilocale: 'Bilocale',
  appartamento: 'Appartamento intero',
  altro: 'Altro',
};

export async function getStaticPaths() {
  const buildDate = new Date().toISOString().split('T')[0];

  const { data, error } = await supabase
    .from('alloggi')
    .select('id, titolo, tipo, citta, zona, prezzo, spese_incluse, disponibile_da, descrizione, foto_url, foto_urls, inserzionista_nome, inserzionista_email, inserzionista_telefono, scade_il')
    .eq('stato', 'pubblicato')
    .gte('scade_il', buildDate);

  if (error) {
    console.error('[alloggi/[id]] Errore Supabase in getStaticPaths():');
    console.error('  message:', error.message);
    if (error.code)    console.error('  code:   ', error.code);
    if (error.details) console.error('  details:', error.details);
    if (error.hint)    console.error('  hint:   ', error.hint);
    return [];
  }

  const count = data?.length ?? 0;
  if (count === 0) {
    console.warn('[alloggi/[id]] Nessun annuncio pubblicato e non scaduto trovato in Supabase.');
  } else {
    console.log(`[alloggi/[id]] Alloggi pubblicati e non scaduti trovati: ${count}`);
  }

  return (data ?? []).map((a) => ({
    params: { id: a.id as string },
    props: { annuncio: a as Annuncio },
  }));
}

const { annuncio } = Astro.props as { annuncio: Annuncio };

const tipoLabel = TIPO_LABEL[annuncio.tipo] ?? annuncio.tipo;
const localita = annuncio.zona ? `${annuncio.citta} — ${annuncio.zona}` : annuncio.citta;

const fotografie: string[] =
  Array.isArray(annuncio.foto_urls) && annuncio.foto_urls.length > 0
    ? (annuncio.foto_urls as string[])
    : annuncio.foto_url
    ? [annuncio.foto_url]
    : [];

let disponibileLabel: string | null = null;
if (annuncio.disponibile_da) {
  disponibileLabel = new Intl.DateTimeFormat('it-IT', {
    day: 'numeric', month: 'long', year: 'numeric',
  }).format(new Date(annuncio.disponibile_da + 'T00:00:00'));
}

let scadeLabel: string | null = null;
if (annuncio.scade_il) {
  scadeLabel = new Intl.DateTimeFormat('it-IT', {
    day: 'numeric', month: 'long', year: 'numeric',
  }).format(new Date(annuncio.scade_il + 'T00:00:00'));
}

const mailtoHref = `mailto:${annuncio.inserzionista_email}?subject=${encodeURIComponent('Richiesta informazioni: ' + annuncio.titolo)}`;
const telHref = annuncio.inserzionista_telefono
  ? `tel:${annuncio.inserzionista_telefono.replace(/\s+/g, '')}`
  : null;

const rimozioneMailtoHref =
  `mailto:areanuova@unifg.it` +
  `?subject=${encodeURIComponent('Richiesta modifica/rimozione annuncio: ' + annuncio.titolo)}` +
  `&body=${encodeURIComponent(
    'ID annuncio: ' + annuncio.id + '\n' +
    'Titolo annuncio: ' + annuncio.titolo + '\n' +
    'Tipo richiesta: \n' +
    'Messaggio: '
  )}`;

const segnalaMailtoHref =
  `mailto:areanuova@unifg.it` +
  `?subject=${encodeURIComponent('Segnalazione annuncio: ' + annuncio.titolo)}` +
  `&body=${encodeURIComponent(
    'ID annuncio: ' + annuncio.id + '\n' +
    'Titolo annuncio: ' + annuncio.titolo + '\n' +
    'Link annuncio: /alloggi/' + annuncio.id + '\n' +
    'Motivo della segnalazione: \n' +
    'Dettagli: '
  )}`;
---

<BaseLayout
  titolo={`${annuncio.titolo} — Area Nuova Alloggi`}
  descrizione={`${tipoLabel} a ${localita}. €${annuncio.prezzo}/mese. Pubblicato su Area Nuova Alloggi.`}
>
  <article class="container-site max-w-3xl py-16">

    <a href="/alloggi" class="text-sm font-semibold text-primary-800 hover:underline">← Torna alla bacheca</a>

    <!-- GALLERIA FOTO -->
    <div class="mt-8">
      {fotografie.length === 0 ? (
        <div class="flex h-64 items-center justify-center rounded-2xl bg-slate-100">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24"
            fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round"
            stroke-linejoin="round" class="text-slate-300">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
            <polyline points="9 22 9 12 15 12 15 22" />
          </svg>
        </div>
      ) : (
        <div>
          <!-- Foto principale -->
          <div class="overflow-hidden rounded-2xl">
            <img
              src={fotografie[0]}
              alt={annuncio.titolo}
              class="h-72 w-full object-cover sm:h-96"
              loading="eager"
            />
          </div>
          <!-- Foto aggiuntive -->
          {fotografie.length > 1 && (
            <div class="mt-2 grid grid-cols-2 gap-2 sm:grid-cols-4">
              {fotografie.slice(1).map((url, i) => (
                <div class="overflow-hidden rounded-xl">
                  <img
                    src={url}
                    alt={`${annuncio.titolo} — foto ${i + 2}`}
                    class="h-24 w-full object-cover"
                    loading="lazy"
                  />
                </div>
              ))}
            </div>
          )}
        </div>
      )}
    </div>

    <!-- INTESTAZIONE -->
    <div class="mt-8">
      <span class="rounded-full bg-primary-100 px-3 py-1 text-xs font-semibold text-primary-800">
        {tipoLabel}
      </span>
      <h1 class="mt-3 text-2xl font-bold sm:text-3xl">{annuncio.titolo}</h1>
      <p class="mt-2 flex items-center gap-1.5 text-slate-600">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
          stroke-linejoin="round" class="shrink-0">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
          <circle cx="12" cy="10" r="3" />
        </svg>
        {localita}
      </p>
    </div>

    <!-- PREZZO E DETTAGLI RAPIDI -->
    <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div>
          <p class="text-3xl font-bold text-slate-900">
            €{annuncio.prezzo}<span class="text-base font-normal text-slate-500">/mese</span>
          </p>
          {annuncio.spese_incluse && (
            <span class="mt-2 inline-block rounded-full bg-green-100 px-3 py-1 text-xs font-semibold text-green-800">
              Spese incluse
            </span>
          )}
        </div>
        {disponibileLabel && (
          <div class="text-right text-sm text-slate-600">
            <p class="font-semibold text-slate-800">Disponibile dal</p>
            <p>{disponibileLabel}</p>
          </div>
        )}
      </div>
      {scadeLabel && (
        <p class="mt-4 border-t border-slate-100 pt-4 text-xs text-slate-400">
          Annuncio visibile fino al {scadeLabel}
        </p>
      )}
    </div>

    <!-- DESCRIZIONE -->
    <div class="mt-8">
      <h2 class="text-lg font-bold text-slate-900">Descrizione</h2>
      <p class="mt-3 whitespace-pre-line text-sm leading-relaxed text-slate-700">
        {annuncio.descrizione}
      </p>
    </div>

    <!-- CONTATTI -->
    <div class="mt-8 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-base font-bold text-slate-900">Contatta l'inserzionista</h2>
      <p class="mt-1 text-sm text-slate-600">
        Pubblicato da <span class="font-semibold text-slate-800">{annuncio.inserzionista_nome}</span>
      </p>

      <div class="mt-4 flex flex-col gap-3 sm:flex-row">
        <a
          href={mailtoHref}
          class="flex items-center justify-center gap-2 rounded-xl bg-primary-800 px-5 py-3 text-sm font-semibold text-white hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
            fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
            stroke-linejoin="round">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
            <polyline points="22,6 12,13 2,6" />
          </svg>
          Scrivi un'email
        </a>

        {telHref && (
          <a
            href={telHref}
            class="flex items-center justify-center gap-2 rounded-xl border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-800 hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
              fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
              stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.56 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16.92z" />
            </svg>
            Chiama / WhatsApp
          </a>
        )}
      </div>

      <div class="mt-4 rounded-xl border border-amber-200 bg-amber-50 p-4 text-sm text-amber-900">
        <p class="font-semibold">Attenzione</p>
        <p class="mt-1">
          Contatta l'inserzionista solo per informazioni sull'annuncio. Non inviare documenti
          personali o pagamenti prima di aver verificato l'identità della controparte e visionato
          l'immobile di persona.
        </p>
        <div class="mt-3 flex flex-wrap gap-4 text-xs font-semibold">
          <a href="/alloggi/sicurezza" class="text-primary-800 hover:underline">Consigli di sicurezza →</a>
          <a href="/alloggi/privacy" class="text-primary-800 hover:underline">Informativa privacy →</a>
          <a href="/alloggi/termini" class="text-primary-800 hover:underline">Termini di utilizzo →</a>
        </div>
      </div>
    </div>

    <!-- SICUREZZA -->
    <div class="mt-8">
      <SicurezzaBadge />
    </div>

    <!-- DISCLAIMER -->
    <div class="mt-6">
      <DisclaimerBox compact />
    </div>

    <!-- NAVIGAZIONE -->
    <div class="mt-10 border-t border-slate-200 pt-6 flex flex-wrap items-center justify-between gap-3">
      <a href="/alloggi" class="text-sm font-semibold text-primary-800 hover:underline">← Torna alla bacheca</a>
      <div class="flex flex-wrap items-center gap-4">
        <a href={segnalaMailtoHref} class="text-xs text-slate-500 hover:text-primary-800 hover:underline">
          Segnala annuncio
        </a>
        <span class="text-xs text-slate-300" aria-hidden="true">·</span>
        <a href={rimozioneMailtoHref} class="text-xs text-slate-500 hover:text-primary-800 hover:underline">
          Richiedi modifica o rimozione
        </a>
      </div>
    </div>

  </article>
</BaseLayout>
