---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/ui/PageHeader.astro';
import YoutubeEmbed from '../../components/video/YoutubeEmbed.astro';
import { formattaData } from '../../lib/utils';
import sito from '../../data/sito.json';

const video = (await getCollection('video', ({ data }) => data.stato === 'published')).sort((a, b) => a.data.ordine - b.data.ordine);
const inEvidenza = video.find((v) => v.data.inEvidenza) ?? video[0];
const altri = video.filter((v) => v.slug !== inEvidenza?.slug);
---

<BaseLayout titolo="Video" descrizione="I video ufficiali di Area Nuova: interventi, eventi e iniziative per gli studenti UniFg.">
  <PageHeader
    occhiello="Canale YouTube"
    titolo="Video"
    sottotitolo="Interventi, eventi e iniziative di Area Nuova raccontati per immagini."
  />

  <section class="container-site py-16">
    {sito.social.youtube && (
      <div class="mb-10">
        <a
          href={sito.social.youtube}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg bg-accent-500 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-accent-600"
        >
          Vai al canale YouTube →
        </a>
      </div>
    )}

    {!inEvidenza ? (
      <p class="text-slate-500">Nessun video pubblicato al momento.</p>
    ) : (
      <>
        <!-- VIDEO IN EVIDENZA -->
        <div class="mb-16">
          <h2 class="mb-4 text-xl font-bold text-slate-900">In evidenza</h2>
          <div class="overflow-hidden rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
            <YoutubeEmbed youtubeId={inEvidenza.data.youtubeId} title={inEvidenza.data.titolo} />
            <div class="mt-4">
              <time class="text-xs font-semibold uppercase tracking-wide text-slate-500">{formattaData(inEvidenza.data.data)}</time>
              <h3 class="mt-1 text-lg font-bold text-slate-900">
                <a href={`/video/${inEvidenza.slug}`} class="hover:text-primary-800">{inEvidenza.data.titolo}</a>
              </h3>
              {inEvidenza.data.descrizione && <p class="mt-2 text-sm text-slate-600">{inEvidenza.data.descrizione}</p>}
            </div>
          </div>
        </div>

        <!-- ALTRI VIDEO -->
        {altri.length > 0 && (
          <div>
            <h2 class="mb-6 text-xl font-bold text-slate-900">Tutti i video</h2>
            <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
              {altri.map((v) => (
                <div class="overflow-hidden rounded-2xl bg-white p-4 shadow-sm ring-1 ring-slate-200">
                  <YoutubeEmbed youtubeId={v.data.youtubeId} title={v.data.titolo} />
                  <div class="mt-3">
                    <time class="text-xs font-semibold uppercase tracking-wide text-slate-500">{formattaData(v.data.data)}</time>
                    <h3 class="mt-1 font-bold text-slate-900">
                      <a href={`/video/${v.slug}`} class="hover:text-primary-800">{v.data.titolo}</a>
                    </h3>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}
      </>
    )}
  </section>
</BaseLayout>
