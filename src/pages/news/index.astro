---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/ui/PageHeader.astro';
import NewsCard from '../../components/ui/NewsCard.astro';

const news = (await getCollection('news', ({ data }) => !data.bozza))
  .sort((a, b) => b.data.data.getTime() - a.data.data.getTime());
---

<BaseLayout titolo="News" descrizione="Le ultime novità  di Area Nuova.">
  <PageHeader occhiello="Aggiornamenti" titolo="News" sottotitolo="Comunicazioni, aggiornamenti e novità  dall'associazione." />

  <section class="container-site py-16">
    {news.length === 0 ? (
      <p class="text-slate-500">Nessuna news pubblicata al momento.</p>
    ) : (
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {news.map((n) => <NewsCard articolo={n} />)}
      </div>
    )}
  </section>
</BaseLayout>
