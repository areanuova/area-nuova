---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/ui/PageHeader.astro';
import EventoCard from '../../components/ui/EventoCard.astro';
import FilterBar from '../../components/ui/FilterBar.astro';
import { eFuturo } from '../../lib/utils';

const tutti = await getCollection('eventi');

const prossimi = tutti
  .filter((e) => eFuturo(e.data.data))
  .sort((a, b) => a.data.data.getTime() - b.data.data.getTime());

const passati = tutti
  .filter((e) => !eFuturo(e.data.data))
  .sort((a, b) => b.data.data.getTime() - a.data.data.getTime());

const inEvidenza = prossimi.find((e) => e.data.inEvidenza) ?? null;
const altriProssimi = prossimi.filter((e) => !e.data.inEvidenza || e !== inEvidenza);

const labelCategoria: Record<string, string> = {
  assemblea: 'Assemblea',
  orientamento: 'Orientamento',
  formazione: 'Formazione',
  culturale: 'Culturale',
  altro: 'Altro',
};

const categoriePresenti = [...new Set(prossimi.map((e) => e.data.categoria))];
const categorieFiltro = categoriePresenti.map((c) => labelCategoria[c] ?? c);
---

<BaseLayout titolo="Eventi" descrizione="Gli eventi organizzati da Area Nuova: assemblee, orientamento e iniziative aperte agli studenti.">
  <PageHeader occhiello="Calendario" titolo="Eventi" sottotitolo="Incontri, assemblee e iniziative aperte agli studenti." />

  <section class="container-site py-16">

    {/* Evento in evidenza */}
    {inEvidenza && (
      <div class="mb-14">
        <p class="mb-4 text-xs font-bold uppercase tracking-widest text-primary-700">Prossimo evento</p>
        <div class="max-w-2xl">
          <EventoCard evento={inEvidenza} />
        </div>
      </div>
    )}

    {/* Prossimi eventi */}
    <h2 class="mb-6 text-2xl font-bold">Prossimi eventi</h2>

    {altriProssimi.length === 0 && !inEvidenza ? (
      <p class="text-slate-500">Nessun evento in programma al momento.</p>
    ) : altriProssimi.length === 0 ? (
      <p class="text-slate-500">Nessun altro evento in programma.</p>
    ) : (
      <>
        {categorieFiltro.length > 1 && (
          <FilterBar categorie={categorieFiltro} targetId="griglia-prossimi" />
        )}
        <div id="griglia-prossimi" class="grid gap-6 md:grid-cols-2">
          {altriProssimi.map((e) => (
            <div data-cat={labelCategoria[e.data.categoria] ?? e.data.categoria}>
              <EventoCard evento={e} />
            </div>
          ))}
        </div>
      </>
    )}

    {/* Archivio passati */}
    {passati.length > 0 && (
      <>
        <h2 class="mb-6 mt-16 text-2xl font-bold">Archivio eventi</h2>
        <div class="grid gap-6 md:grid-cols-2">
          {passati.map((e) => <EventoCard evento={e} />)}
        </div>
      </>
    )}

  </section>
</BaseLayout>
