---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout titolo="Pagina non trovata" descrizione="La pagina che stai cercando non esiste o è stata spostata.">
  <section class="border-b border-slate-200 bg-gradient-to-b from-primary-50 to-white">
    <div class="container-site py-12 sm:py-16 text-center">
      <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-accent-600">Errore 404</p>
      <h1 class="text-3xl font-bold sm:text-4xl">Pagina non trovata</h1>
      <p class="mt-4 max-w-xl mx-auto text-lg text-slate-600">
        La pagina che stai cercando non esiste o è stata spostata.
      </p>
    </div>
  </section>

  <section class="container-site py-16 text-center">
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="/"
        class="inline-block rounded-xl bg-primary-800 px-6 py-3 text-sm font-semibold text-white hover:bg-primary-900 transition-colors"
      >
        Torna alla homepage
      </a>
      <a
        href="/segnalazioni"
        class="inline-block rounded-xl bg-white px-6 py-3 text-sm font-semibold text-primary-800 ring-1 ring-primary-800 hover:bg-primary-50 transition-colors"
      >
        Segnala un problema
      </a>
      <a
        href="/guide"
        class="inline-block rounded-xl bg-white px-6 py-3 text-sm font-semibold text-slate-700 ring-1 ring-slate-300 hover:bg-slate-50 transition-colors"
      >
        Vai alle guide
      </a>
    </div>
  </section>
</BaseLayout>
