---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/ui/PageHeader.astro';
import FilterBar from '../../components/ui/FilterBar.astro';

const guide = (await getCollection('guide', ({ data }) => data.stato === 'published')).sort((a, b) => a.data.ordine - b.data.ordine);
const matricole = guide.filter((g) => g.data.perMatricole);
const categorie = [...new Set(guide.map((g) => g.data.categoria))];
---

<BaseLayout titolo="Guide utili" descrizione="Guide pratiche per studenti dell'Università  di Foggia.">
  <PageHeader
    occhiello="Per gli studenti"
    titolo="Guide utili"
    sottotitolo="Tutto quello che serve per orientarsi nella vita universitaria, spiegato in modo semplice."
  />

  <!-- SEZIONE MATRICOLE -->
  {matricole.length > 0 && (
    <section class="bg-accent-50">
      <div class="container-site py-12">
        <div class="flex items-center gap-3">
          <span class="rounded-full bg-accent-500 px-3 py-1 text-xs font-bold uppercase tracking-wide text-white">Matricole</span>
          <h2 class="text-2xl font-bold text-accent-900">Sei al primo anno? Inizia da qui</h2>
        </div>
        <div class="mt-6 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {matricole.map((g) => (
            <a href={`/guide/${g.slug}`} class="rounded-2xl bg-white p-5 shadow-sm ring-1 ring-accent-200 transition-shadow hover:shadow-md">
              <h3 class="font-bold text-slate-900">{g.data.titolo}</h3>
              {g.data.estratto && <p class="mt-1 text-sm text-slate-600">{g.data.estratto}</p>}
              <span class="mt-3 inline-block text-sm font-semibold text-accent-700">Leggi la guida →</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- TUTTE LE GUIDE -->
  <section class="container-site py-16">
    <h2 class="mb-6 text-2xl font-bold">Tutte le guide</h2>
    {guide.length === 0 ? (
      <p class="text-slate-500">Nessuna guida pubblicata al momento.</p>
    ) : (
      <>
        {categorie.length > 1 && <FilterBar categorie={categorie} targetId="lista-guide" />}
        <div id="lista-guide" class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {guide.map((g) => (
            <a href={`/guide/${g.slug}`} data-cat={g.data.categoria} class="flex flex-col rounded-2xl bg-white p-5 shadow-sm ring-1 ring-slate-200 transition-shadow hover:shadow-md">
              <span class="text-xs font-semibold uppercase tracking-wide text-primary-700">{g.data.categoria}</span>
              <h3 class="mt-1 font-bold text-slate-900">{g.data.titolo}</h3>
              {g.data.estratto && <p class="mt-1 flex-1 text-sm text-slate-600">{g.data.estratto}</p>}
              <span class="mt-3 text-sm font-semibold text-primary-800">Leggi la guida →</span>
            </a>
          ))}
        </div>
      </>
    )}
  </section>
</BaseLayout>
