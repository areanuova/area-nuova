---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/ui/PageHeader.astro';

const tutti = (await getCollection('documenti', ({ data }) => data.stato === 'published')).sort((a, b) => b.data.anno - a.data.anno);
const proposte = tutti.filter((d) => d.data.tipo === 'proposta');
const richieste = tutti.filter((d) => d.data.tipo === 'richiesta');

const badge: Record<string, { label: string; cls: string }> = {
  proposta: { label: 'Proposta', cls: 'bg-accent-100 text-accent-800' },
  richiesta: { label: 'Richiesta', cls: 'bg-primary-100 text-primary-800' },
};

const isPdf = (file: string) => file.toLowerCase().endsWith('.pdf');
---

<BaseLayout titolo="Mozioni e Documenti" descrizione="Proposte, richieste e atti ufficiali di Area Nuova.">
  <PageHeader
    occhiello="Atti ufficiali"
    titolo="Mozioni e Documenti"
    sottotitolo="Le proposte progettuali e le richieste ufficiali presentate da Area Nuova agli organi dell'Ateneo."
  />

  <section class="container-site py-16 space-y-16">

    <!-- PROPOSTE -->
    <div>
      <h2 class="mb-6 text-2xl font-bold">Proposte</h2>
      {proposte.length === 0 ? (
        <p class="text-slate-500">Nessuna proposta disponibile al momento.</p>
      ) : (
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {proposte.map((d) => (
            <div class="flex flex-col rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
              <div class="flex items-center justify-between gap-2">
                <span class={`rounded-full px-2.5 py-0.5 text-xs font-semibold ${badge[d.data.tipo].cls}`}>
                  {badge[d.data.tipo].label}
                </span>
                <span class="text-xs text-slate-400">{d.data.anno}</span>
              </div>
              <h3 class="mt-3 font-bold text-slate-900 leading-snug">{d.data.titolo}</h3>
              <p class="mt-1 text-xs font-medium text-slate-500">{d.data.categoria}</p>
              {d.data.descrizione && (
                <p class="mt-3 flex-1 text-sm text-slate-600">{d.data.descrizione}</p>
              )}
              <a
                href={d.data.file}
                target={isPdf(d.data.file) ? '_blank' : undefined}
                rel={isPdf(d.data.file) ? 'noopener noreferrer' : undefined}
                class="mt-5 inline-flex items-center gap-2 rounded-xl bg-accent-700 px-4 py-2.5 text-sm font-semibold text-white hover:bg-accent-800 transition-colors"
              >
                {isPdf(d.data.file) ? (
                  <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                ) : (
                  <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                )}
                {isPdf(d.data.file) ? 'Scarica PDF' : 'Scopri di più'}
              </a>
            </div>
          ))}
        </div>
      )}
    </div>

    <!-- RICHIESTE -->
    <div>
      <h2 class="mb-6 text-2xl font-bold">Richieste</h2>
      {richieste.length === 0 ? (
        <p class="text-slate-500">Nessuna richiesta disponibile al momento.</p>
      ) : (
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {richieste.map((d) => (
            <div class="flex flex-col rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
              <div class="flex items-center justify-between gap-2">
                <span class={`rounded-full px-2.5 py-0.5 text-xs font-semibold ${badge[d.data.tipo].cls}`}>
                  {badge[d.data.tipo].label}
                </span>
                <span class="text-xs text-slate-400">{d.data.anno}</span>
              </div>
              <h3 class="mt-3 font-bold text-slate-900 leading-snug">{d.data.titolo}</h3>
              <p class="mt-1 text-xs font-medium text-slate-500">{d.data.categoria}</p>
              {d.data.descrizione && (
                <p class="mt-3 flex-1 text-sm text-slate-600">{d.data.descrizione}</p>
              )}
              <a
                href={d.data.file}
                target={isPdf(d.data.file) ? '_blank' : undefined}
                rel={isPdf(d.data.file) ? 'noopener noreferrer' : undefined}
                class="mt-5 inline-flex items-center gap-2 rounded-xl bg-primary-800 px-4 py-2.5 text-sm font-semibold text-white hover:bg-primary-900 transition-colors"
              >
                {isPdf(d.data.file) ? (
                  <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                ) : (
                  <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                )}
                {isPdf(d.data.file) ? 'Scarica PDF' : 'Scopri di più'}
              </a>
            </div>
          ))}
        </div>
      )}
    </div>

  </section>
</BaseLayout>
