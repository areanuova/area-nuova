---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout titolo="Dashboard" minRole="editor">
  <div class="mx-auto max-w-5xl space-y-8">

    <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-sm font-bold uppercase tracking-wide text-slate-500">Il tuo accesso</h2>
      <div class="mt-3 flex flex-wrap items-center gap-3">
        <span id="dash-role" class="text-lg font-bold text-slate-900"></span>
      </div>
      <p id="dash-compat-note" class="mt-2 hidden text-sm text-amber-700">
        Il tuo ruolo è assegnato in <strong>modalità compatibilità</strong> — non è stato letto dal database come
        ruolo reale. Verifica lo stato della migration dei ruoli.
      </p>
    </section>

    <section id="dash-stats" class="hidden">
      <h2 class="mb-3 text-sm font-bold uppercase tracking-wide text-slate-500">Panoramica contenuti</h2>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-2xl border border-accent-200 bg-accent-50 p-4">
          <p class="text-xs font-semibold uppercase text-accent-700">Pubblicati</p>
          <p id="dash-stat-published" class="mt-1 text-2xl font-bold text-accent-900">–</p>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
          <p class="text-xs font-semibold uppercase text-slate-600">Bozze</p>
          <p id="dash-stat-draft" class="mt-1 text-2xl font-bold text-slate-900">–</p>
        </div>
        <div class="rounded-2xl border border-amber-200 bg-amber-50 p-4">
          <p class="text-xs font-semibold uppercase text-amber-700">In revisione</p>
          <p id="dash-stat-review" class="mt-1 text-2xl font-bold text-amber-900">–</p>
        </div>
        <div class="rounded-2xl border border-red-200 bg-red-50 p-4">
          <p class="text-xs font-semibold uppercase text-red-700">Archiviati</p>
          <p id="dash-stat-archived" class="mt-1 text-2xl font-bold text-red-900">–</p>
        </div>
      </div>

      <div id="dash-attention" class="mt-4 hidden space-y-3">
        <div id="dash-att-scadenza" class="hidden rounded-xl border border-amber-200 bg-amber-50 p-4 text-sm text-amber-800"></div>
        <div id="dash-att-verifica" class="hidden rounded-xl border border-amber-200 bg-amber-50 p-4 text-sm text-amber-800"></div>
        <div id="dash-att-incompleti" class="hidden rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-700"></div>
        <div id="dash-att-github" class="hidden rounded-xl border border-red-200 bg-red-50 p-4 text-sm text-red-800"></div>
      </div>
    </section>

    <section>
      <h2 class="mb-3 text-sm font-bold uppercase tracking-wide text-slate-500">Moduli</h2>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <a href="/admin/partnership" class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition-shadow hover:shadow-md">
          <h3 class="font-bold text-slate-900">Partnership</h3>
          <p class="mt-1 text-sm text-slate-600">Crea, modifica e pubblica le partnership del sito.</p>
          <span class="mt-3 inline-block text-sm font-semibold text-primary-800">Gestisci →</span>
        </a>
        <a href="/admin/contenuti/gruppi-whatsapp" class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition-shadow hover:shadow-md">
          <h3 class="font-bold text-slate-900">Gruppi WhatsApp</h3>
          <p class="mt-1 text-sm text-slate-600">Gruppi, community e canali WhatsApp UniFg, con QR e import/export.</p>
          <span class="mt-3 inline-block text-sm font-semibold text-primary-800">Gestisci →</span>
        </a>
        <a href="/admin/alloggi" class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition-shadow hover:shadow-md">
          <h3 class="font-bold text-slate-900">Alloggi</h3>
          <p class="mt-1 text-sm text-slate-600">Modera gli annunci inviati dagli studenti (pannello esistente).</p>
          <span class="mt-3 inline-block text-sm font-semibold text-primary-800">Apri →</span>
        </a>
        <a href="/admin/contenuti/news" class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition-shadow hover:shadow-md">
          <h3 class="font-bold text-slate-900">News</h3>
          <p class="mt-1 text-sm text-slate-600">Comunicati, risultati, resoconti e avvisi.</p>
          <span class="mt-3 inline-block text-sm font-semibold text-primary-800">Gestisci →</span>
        </a>
        <a href="/admin/contenuti/guide" class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition-shadow hover:shadow-md">
          <h3 class="font-bold text-slate-900">Guide</h3>
          <p class="mt-1 text-sm text-slate-600">Guide utili per gli studenti, incluse quelle per matricole.</p>
          <span class="mt-3 inline-block text-sm font-semibold text-primary-800">Gestisci →</span>
        </a>
        <a href="/admin/contenuti/documenti" class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition-shadow hover:shadow-md">
          <h3 class="font-bold text-slate-900">Documenti</h3>
          <p class="mt-1 text-sm text-slate-600">Mozioni, proposte, richieste e modulistica.</p>
          <span class="mt-3 inline-block text-sm font-semibold text-primary-800">Gestisci →</span>
        </a>
        <a href="/admin/contenuti/progetti" class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition-shadow hover:shadow-md">
          <h3 class="font-bold text-slate-900">Progetti</h3>
          <p class="mt-1 text-sm text-slate-600">Archivio progetti e iniziative di Area Nuova.</p>
          <span class="mt-3 inline-block text-sm font-semibold text-primary-800">Gestisci →</span>
        </a>
        <a href="/admin/contenuti/video" class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition-shadow hover:shadow-md">
          <h3 class="font-bold text-slate-900">Video</h3>
          <p class="mt-1 text-sm text-slate-600">Video del canale YouTube di Area Nuova.</p>
          <span class="mt-3 inline-block text-sm font-semibold text-primary-800">Gestisci →</span>
        </a>
        <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
          <h3 class="font-bold text-slate-900">Decap CMS</h3>
          <p class="mt-1 text-sm text-slate-600">
            Login OAuth GitHub corretto negli Sprint 2.1 (route spostate in <code>src/pages/api/auth.ts</code>), non ancora verificato end-to-end su un deploy reale.
          </p>
          <a href="/admin" class="mt-3 inline-block text-sm font-semibold text-primary-800">Vedi <code>/admin</code> Decap →</a>
        </div>
      </div>
    </section>

    <section>
      <h2 class="mb-3 text-sm font-bold uppercase tracking-wide text-slate-500">Attività recenti</h2>
      <div id="dash-audit-loading" class="text-sm text-slate-500">Caricamento…</div>
      <div id="dash-audit-unavailable" class="hidden rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-500">
        Registro attività non disponibile al momento.
      </div>
      <div id="dash-audit-empty" class="hidden rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-500">
        Nessuna attività registrata finora.
      </div>
      <ul id="dash-audit-list" class="hidden space-y-2"></ul>
    </section>

  </div>
</AdminLayout>

<script>
  import { ROLE_LABEL, hasPermission } from '../../lib/admin/roles';
  import { onAdminReady } from '../../lib/admin/ready';

  onAdminReady(async ({ user, accessToken }) => {

    document.getElementById('dash-role')!.textContent = ROLE_LABEL[user.role as keyof typeof ROLE_LABEL];
    if (user.compatibilityMode) {
      document.getElementById('dash-compat-note')!.classList.remove('hidden');
    }

    // --- Panoramica contenuti ---
    try {
      const res = await fetch('/api/admin/dashboard/stats', { headers: { Authorization: `Bearer ${accessToken}` } });
      if (res.ok) {
        const stats = await res.json();
        document.getElementById('dash-stats')!.classList.remove('hidden');
        document.getElementById('dash-stat-published')!.textContent = String(stats.riepilogo.totalePubblicati);
        document.getElementById('dash-stat-draft')!.textContent = String(stats.riepilogo.totaleBozze);
        document.getElementById('dash-stat-review')!.textContent = String(stats.riepilogo.totaleRevisione);
        document.getElementById('dash-stat-archived')!.textContent = String(stats.riepilogo.totaleArchiviati);

        const attention = document.getElementById('dash-attention')!;
        let mostraAttention = false;

        if (stats.gruppiInScadenza.length > 0) {
          mostraAttention = true;
          const el = document.getElementById('dash-att-scadenza')!;
          el.classList.remove('hidden');
          el.innerHTML = `<strong>${stats.gruppiInScadenza.length}</strong> ${stats.gruppiInScadenza.length === 1 ? 'gruppo WhatsApp in scadenza' : 'gruppi WhatsApp in scadenza'} nei prossimi 14 giorni — <a href="/admin/contenuti/gruppi-whatsapp" class="underline font-semibold">rivedi</a>`;
        }
        if (stats.gruppiDaVerificare.length > 0) {
          mostraAttention = true;
          const el = document.getElementById('dash-att-verifica')!;
          el.classList.remove('hidden');
          el.innerHTML = `<strong>${stats.gruppiDaVerificare.length}</strong> link WhatsApp da verificare (mai verificati o verifica scaduta) — <a href="/admin/contenuti/gruppi-whatsapp" class="underline font-semibold">rivedi</a>`;
        }
        if (stats.contenutiIncompletiTotale > 0) {
          mostraAttention = true;
          const el = document.getElementById('dash-att-incompleti')!;
          el.classList.remove('hidden');
          el.textContent = `${stats.contenutiIncompletiTotale} contenuti con metadati incompleti (descrizione/estratto mancante).`;
        }
        if (!stats.githubConfigurato) {
          mostraAttention = true;
          const el = document.getElementById('dash-att-github')!;
          el.classList.remove('hidden');
          el.textContent = 'GITHUB_SERVICE_TOKEN non configurato in questo ambiente: i salvataggi CMS non verranno pubblicati.';
        }
        attention.classList.toggle('hidden', !mostraAttention);
      }
    } catch {
      // La dashboard resta comunque utilizzabile senza le statistiche.
    }

    const loadingEl = document.getElementById('dash-audit-loading')!;
    const unavailableEl = document.getElementById('dash-audit-unavailable')!;
    const emptyEl = document.getElementById('dash-audit-empty')!;
    const listEl = document.getElementById('dash-audit-list')!;

    if (!hasPermission(user.role, 'audit.view')) {
      loadingEl.classList.add('hidden');
      unavailableEl.textContent = 'Il tuo ruolo non ha accesso al registro attività.';
      unavailableEl.classList.remove('hidden');
      return;
    }

    try {
      const res = await fetch('/api/admin/audit/recent', {
        headers: { Authorization: `Bearer ${accessToken}` },
      });
      const data = await res.json();
      loadingEl.classList.add('hidden');

      if (!res.ok || !data.disponibile) {
        unavailableEl.classList.remove('hidden');
        return;
      }
      if (data.righe.length === 0) {
        emptyEl.classList.remove('hidden');
        return;
      }
      listEl.classList.remove('hidden');
      listEl.innerHTML = data.righe
        .map(
          (r: any) =>
            `<li class="rounded-xl border border-slate-200 bg-white p-3 text-sm">
              <span class="font-semibold">${r.azione}</span> · ${r.collezione} · ${r.entry_id}
              <span class="block text-xs text-slate-400">${new Date(r.created_at).toLocaleString('it-IT')}</span>
            </li>`,
        )
        .join('');
    } catch {
      loadingEl.classList.add('hidden');
      unavailableEl.classList.remove('hidden');
    }
  });
</script>
