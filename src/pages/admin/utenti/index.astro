---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout titolo="Gestione utenti" minRole="super_admin">
  <div class="mx-auto max-w-3xl">
    <section class="mb-8 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-sm font-bold uppercase tracking-wide text-slate-500">Nuovo amministratore</h2>
      <p class="mt-1 text-sm text-slate-600">
        Aggiunge l'email all'allow-list: la persona potrà accedere con il primo magic link richiesto, senza bisogno di un account creato in anticipo.
      </p>
      <form id="us-create-form" class="mt-4 flex flex-wrap items-end gap-3">
        <div class="flex-1 min-w-[220px]">
          <label for="us-new-email" class="block text-xs font-semibold text-slate-700">Email</label>
          <input id="us-new-email" type="email" required placeholder="nome@unifg.it" class="mt-1 w-full rounded-xl border border-slate-300 px-3 py-2 text-sm focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-200" />
        </div>
        <div>
          <label for="us-new-role" class="block text-xs font-semibold text-slate-700">Ruolo</label>
          <select id="us-new-role" class="mt-1 rounded-xl border border-slate-300 px-3 py-2 text-sm focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-200">
            <option value="editor">Editor</option>
            <option value="admin">Admin</option>
            <option value="super_admin">Super Admin</option>
          </select>
        </div>
        <button type="submit" id="us-create-submit" class="rounded-xl bg-primary-800 px-4 py-2.5 text-sm font-semibold text-white hover:bg-primary-700 disabled:cursor-not-allowed disabled:bg-slate-300">
          Aggiungi
        </button>
      </form>
      <p id="us-create-error" role="alert" class="mt-3 hidden text-sm text-red-600"></p>
    </section>

    <div id="us-loading" class="text-sm text-slate-500">Caricamento…</div>
    <div id="us-error" class="hidden rounded-xl border border-red-200 bg-red-50 p-4 text-sm text-red-800"></div>
    <div id="us-list" class="hidden divide-y divide-slate-200 rounded-2xl border border-slate-200 bg-white"></div>
  </div>
</AdminLayout>

<script>
  import { onAdminReady } from '../../../lib/admin/ready';
  import { ROLE_LABEL, type CmsRole } from '../../../lib/admin/roles';

  let accessToken: string | null = null;
  let selfId: string | null = null;

  function escapeHtml(s: string): string {
    return String(s ?? '').replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!));
  }

  async function caricaUtenti() {
    const loadingEl = document.getElementById('us-loading')!;
    const errorEl = document.getElementById('us-error')!;
    const listEl = document.getElementById('us-list')!;

    const res = await fetch('/api/admin/users/list', { headers: { Authorization: `Bearer ${accessToken}` } });
    const data = await res.json();
    loadingEl.classList.add('hidden');

    if (!res.ok) {
      errorEl.textContent = 'Accesso riservato al ruolo Super Admin.';
      errorEl.classList.remove('hidden');
      return;
    }

    listEl.classList.remove('hidden');
    errorEl.classList.add('hidden');
    const righe = data.righe ?? [];
    listEl.innerHTML = righe
      .map((r: any) => {
        const isSelf = r.id === selfId;
        const roleOptions = ['editor', 'admin', 'super_admin']
          .map((v) => `<option value="${v}" ${r.role === v ? 'selected' : ''}>${ROLE_LABEL[v as CmsRole]}</option>`)
          .join('');
        return `
          <div class="flex flex-wrap items-center justify-between gap-3 p-4" data-row-id="${r.id}">
            <div class="min-w-0">
              <p class="font-semibold text-slate-900">${escapeHtml(r.email)}</p>
              <p class="text-xs text-slate-500">dal ${r.created_at ? new Date(r.created_at).toLocaleDateString('it-IT') : 'n/d'}${isSelf ? ' · account corrente' : ''}</p>
            </div>
            <div class="flex items-center gap-2">
              <select class="us-role-select rounded-lg border border-slate-300 px-2 py-1.5 text-sm" data-id="${r.id}" ${isSelf ? 'disabled' : ''}>
                ${roleOptions}
              </select>
              <label class="flex items-center gap-1.5 text-sm text-slate-600">
                <input type="checkbox" class="us-attivo-toggle h-4 w-4 rounded border-slate-300 text-primary-700 focus:ring-primary-500" data-id="${r.id}" ${r.attivo ? 'checked' : ''} ${isSelf ? 'disabled' : ''} />
                Attivo
              </label>
            </div>
          </div>`;
      })
      .join('');

    listEl.querySelectorAll<HTMLSelectElement>('.us-role-select').forEach((el) => {
      el.addEventListener('change', () => aggiornaUtente(el.dataset.id!, { role: el.value }));
    });
    listEl.querySelectorAll<HTMLInputElement>('.us-attivo-toggle').forEach((el) => {
      el.addEventListener('change', () => aggiornaUtente(el.dataset.id!, { attivo: el.checked }));
    });
  }

  async function aggiornaUtente(id: string, updates: Record<string, unknown>) {
    try {
      const res = await fetch('/api/admin/users/update', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${accessToken}` },
        body: JSON.stringify({ id, ...updates }),
      });
      const data = await res.json();
      if (!res.ok) {
        (window as any).adminToast?.(data.message || data.error || 'Aggiornamento fallito.', 'error');
        await caricaUtenti();
        return;
      }
      (window as any).adminToast?.('Aggiornato correttamente.', 'success');
    } catch (err) {
      (window as any).adminToast?.(String((err as Error)?.message ?? err), 'error');
    }
  }

  onAdminReady(async (detail) => {
    accessToken = detail.accessToken;
    selfId = detail.user.id;

    await caricaUtenti();

    const createForm = document.getElementById('us-create-form') as HTMLFormElement;
    createForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const errEl = document.getElementById('us-create-error')!;
      errEl.classList.add('hidden');

      const emailEl = document.getElementById('us-new-email') as HTMLInputElement;
      const roleEl = document.getElementById('us-new-role') as HTMLSelectElement;
      const submitBtn = document.getElementById('us-create-submit') as HTMLButtonElement;
      submitBtn.disabled = true;

      try {
        const res = await fetch('/api/admin/users/create', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${accessToken}` },
          body: JSON.stringify({ email: emailEl.value.trim(), role: roleEl.value }),
        });
        const data = await res.json();
        if (!res.ok) {
          errEl.textContent = data.message || data.error || 'Creazione fallita.';
          errEl.classList.remove('hidden');
          return;
        }
        emailEl.value = '';
        roleEl.value = 'editor';
        (window as any).adminToast?.('Amministratore aggiunto.', 'success');
        await caricaUtenti();
      } catch (err) {
        errEl.textContent = String((err as Error)?.message ?? err);
        errEl.classList.remove('hidden');
      } finally {
        submitBtn.disabled = false;
      }
    });
  });
</script>
