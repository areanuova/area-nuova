---
export const prerender = false;

import AdminLayout from '../../../../layouts/AdminLayout.astro';
import { getContentType } from '../../../../lib/admin/content-types';

const { tipo } = Astro.params;
const typeDef = getContentType(tipo ?? '');
if (!typeDef) {
  return Astro.redirect('/admin');
}
---

<AdminLayout titolo={typeDef.labelPlurale} minRole="editor">
  <div class="mx-auto max-w-5xl">
    <div class="mb-6 flex flex-wrap items-center justify-between gap-3">
      <div class="flex flex-wrap gap-2">
        <input id="cl-search" type="search" placeholder="Cerca per titolo…" class="rounded-xl border border-slate-300 px-4 py-2 text-sm focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-200" />
        <select id="cl-filter-stato" class="rounded-xl border border-slate-300 px-3 py-2 text-sm focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-200">
          <option value="">Tutti gli stati</option>
          <option value="draft">Bozza</option>
          <option value="review">In revisione</option>
          <option value="published">Pubblicato</option>
          <option value="archived">Archiviato</option>
        </select>
      </div>
      <div class="flex flex-wrap gap-2">
        {tipo === 'gruppi-whatsapp' && (
          <>
            <button id="cl-export-csv" type="button" class="rounded-xl border border-slate-300 px-4 py-2.5 text-sm font-semibold text-slate-700 hover:border-primary-500 hover:text-primary-800">Esporta CSV</button>
            <button id="cl-export-json" type="button" class="rounded-xl border border-slate-300 px-4 py-2.5 text-sm font-semibold text-slate-700 hover:border-primary-500 hover:text-primary-800">Esporta JSON</button>
            <a href="/admin/contenuti/gruppi-whatsapp/importa" class="rounded-xl border border-slate-300 px-4 py-2.5 text-sm font-semibold text-slate-700 hover:border-primary-500 hover:text-primary-800">Importa</a>
          </>
        )}
        <a id="cl-new-link" href={`/admin/contenuti/${tipo}/nuova`} class="rounded-xl bg-accent-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-accent-700">+ Nuovo</a>
      </div>
    </div>

    <p id="cl-nota" class="mb-4 hidden text-xs text-slate-500"></p>

    <div id="cl-bulk-bar" class="mb-4 hidden flex-wrap items-center gap-3 rounded-xl border border-primary-200 bg-primary-50 p-3">
      <span id="cl-bulk-count" class="text-sm font-semibold text-primary-900"></span>
      <select id="cl-bulk-stato" class="rounded-lg border border-slate-300 px-2 py-1.5 text-sm">
        <option value="draft">→ Bozza</option>
        <option value="review">→ In revisione</option>
        <option value="published">→ Pubblicato</option>
        <option value="archived">→ Archiviato</option>
      </select>
      <button id="cl-bulk-apply" type="button" class="rounded-lg bg-primary-800 px-3 py-1.5 text-sm font-semibold text-white hover:bg-primary-700">Applica stato</button>
      <button id="cl-bulk-archive" type="button" class="rounded-lg border border-red-300 px-3 py-1.5 text-sm font-semibold text-red-700 hover:bg-red-50">Archivia selezionati</button>
      <button id="cl-bulk-clear" type="button" class="text-sm text-slate-500 hover:underline">Deseleziona tutto</button>
    </div>

    <div id="cl-loading" class="text-sm text-slate-500">Caricamento…</div>
    <div id="cl-empty" class="hidden rounded-xl border border-dashed border-slate-300 bg-slate-50 p-8 text-center text-sm text-slate-500">
      Nessun contenuto trovato.
    </div>
    <div id="cl-error" class="hidden rounded-xl border border-red-200 bg-red-50 p-4 text-sm text-red-800"></div>
    <div id="cl-list" class="hidden divide-y divide-slate-200 rounded-2xl border border-slate-200 bg-white"></div>
  </div>
</AdminLayout>

<script>
  import { STATO_LABEL, hasPermission, type CmsRole, type ContentStato } from '../../../../lib/admin/roles';
  import { onAdminReady } from '../../../../lib/admin/ready';
  import { CONTENT_TYPES } from '../../../../lib/admin/content-types';

  const tipo = window.location.pathname.split('/').filter(Boolean)[2] ?? '';
  const typeDef = CONTENT_TYPES[tipo];

  let righeComplete: any[] = [];
  let currentUser: { role: CmsRole } | null = null;
  let accessToken: string | null = null;
  const selezionati = new Set<string>();

  const STATO_STYLE: Record<ContentStato, string> = {
    draft: 'bg-slate-100 text-slate-700',
    review: 'bg-amber-100 text-amber-800',
    published: 'bg-accent-100 text-accent-800',
    archived: 'bg-red-50 text-red-700',
  };

  function escapeHtml(s: string): string {
    return String(s ?? '').replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!));
  }

  function render() {
    if (!typeDef) return;
    const search = (document.getElementById('cl-search') as HTMLInputElement).value.trim().toLowerCase();
    const filtroStato = (document.getElementById('cl-filter-stato') as HTMLSelectElement).value;
    const statoField = typeDef.statoField;

    const righe = righeComplete.filter((r) => {
      if (filtroStato && r[statoField] !== filtroStato) return false;
      if (search && !String(r[typeDef.titleField] ?? '').toLowerCase().includes(search)) return false;
      return true;
    });

    const listEl = document.getElementById('cl-list')!;
    const emptyEl = document.getElementById('cl-empty')!;

    if (righe.length === 0) {
      listEl.classList.add('hidden');
      emptyEl.classList.remove('hidden');
      return;
    }
    emptyEl.classList.add('hidden');
    listEl.classList.remove('hidden');

    const puoModificare = currentUser ? hasPermission(currentUser.role, 'content.edit') : false;

    listEl.innerHTML = righe
      .map((r) => {
        const stato = r[statoField] as ContentStato;
        return `
        <div class="flex items-center justify-between gap-4 p-4">
          <div class="flex min-w-0 items-center gap-3">
            ${puoModificare ? `<input type="checkbox" class="cl-row-check h-4 w-4 rounded border-slate-300" data-slug="${escapeHtml(r.slug)}" ${selezionati.has(r.slug) ? 'checked' : ''} />` : ''}
            <div class="min-w-0">
              <p class="truncate font-semibold text-slate-900">${escapeHtml(r[typeDef.titleField])}</p>
              <p class="truncate text-xs text-slate-500">slug: ${escapeHtml(r.slug)}</p>
            </div>
          </div>
          <span class="shrink-0 rounded-full px-2.5 py-0.5 text-xs font-semibold ${STATO_STYLE[stato] ?? 'bg-slate-100 text-slate-700'}">${STATO_LABEL[stato] ?? stato}</span>
          <div class="flex shrink-0 items-center gap-3">
            ${puoModificare ? `<button type="button" class="cl-duplica-btn text-sm font-semibold text-slate-600 hover:underline" data-slug="${escapeHtml(r.slug)}">Duplica</button>` : ''}
            <a href="/admin/contenuti/${tipo}/${encodeURIComponent(r.slug)}" class="text-sm font-semibold text-primary-800 hover:underline">Modifica →</a>
          </div>
        </div>`;
      })
      .join('');

    listEl.querySelectorAll<HTMLInputElement>('.cl-row-check').forEach((el) => {
      el.addEventListener('change', () => {
        if (el.checked) selezionati.add(el.dataset.slug!);
        else selezionati.delete(el.dataset.slug!);
        aggiornaBarraBulk();
      });
    });
    listEl.querySelectorAll<HTMLButtonElement>('.cl-duplica-btn').forEach((el) => {
      el.addEventListener('click', () => eseguiBulk('duplicate', [el.dataset.slug!]));
    });
  }

  function aggiornaBarraBulk() {
    const bar = document.getElementById('cl-bulk-bar')!;
    const count = document.getElementById('cl-bulk-count')!;
    if (selezionati.size === 0) {
      bar.classList.add('hidden');
      bar.classList.remove('flex');
      return;
    }
    bar.classList.remove('hidden');
    bar.classList.add('flex');
    count.textContent = `${selezionati.size} selezionati`;
  }

  async function eseguiBulk(azione: 'transition' | 'duplicate', slugs: string[], nuovoStato?: string) {
    if (!accessToken || !typeDef) return;
    try {
      const res = await fetch(`/api/admin/contenuti/${tipo}/bulk`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${accessToken}` },
        body: JSON.stringify({ slugs, azione, nuovoStato }),
      });
      const data = await res.json();
      if (!res.ok) {
        (window as any).adminToast?.(data.message || data.error || 'Operazione fallita.', 'error');
        return;
      }
      (window as any).adminToast?.(
        `${data.successi} completati${data.falliti > 0 ? `, ${data.falliti} falliti` : ''}.`,
        data.falliti > 0 ? 'error' : 'success',
      );
      selezionati.clear();
      aggiornaBarraBulk();
      window.location.reload();
    } catch (err) {
      (window as any).adminToast?.(String((err as Error)?.message ?? err), 'error');
    }
  }

  onAdminReady(async (detail) => {
    currentUser = detail.user;
    accessToken = detail.accessToken;

    if (!typeDef) return;

    document.getElementById('cl-search')?.addEventListener('input', render);
    document.getElementById('cl-filter-stato')?.addEventListener('change', render);

    if (currentUser && !hasPermission(currentUser.role, 'content.edit')) {
      document.getElementById('cl-new-link')?.classList.add('hidden');
    }

    async function scaricaExport(formato: 'csv' | 'json') {
      const res = await fetch(`/api/admin/contenuti/gruppi-whatsapp/export?format=${formato}`, {
        headers: { Authorization: `Bearer ${accessToken}` },
      });
      if (!res.ok) {
        (window as any).adminToast?.('Esportazione fallita.', 'error');
        return;
      }
      const blob = await res.blob();
      const a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = `gruppi-whatsapp.${formato}`;
      a.click();
      URL.revokeObjectURL(a.href);
    }
    document.getElementById('cl-export-csv')?.addEventListener('click', () => scaricaExport('csv'));
    document.getElementById('cl-export-json')?.addEventListener('click', () => scaricaExport('json'));

    document.getElementById('cl-bulk-apply')?.addEventListener('click', () => {
      const nuovoStato = (document.getElementById('cl-bulk-stato') as HTMLSelectElement).value;
      if (selezionati.size === 0) return;
      if (!confirm(`Cambiare stato a ${selezionati.size} elementi?`)) return;
      eseguiBulk('transition', Array.from(selezionati), nuovoStato);
    });
    document.getElementById('cl-bulk-archive')?.addEventListener('click', () => {
      if (selezionati.size === 0) return;
      if (!confirm(`Archiviare ${selezionati.size} elementi?`)) return;
      eseguiBulk('transition', Array.from(selezionati), 'archived');
    });
    document.getElementById('cl-bulk-clear')?.addEventListener('click', () => {
      selezionati.clear();
      aggiornaBarraBulk();
      render();
    });

    const loadingEl = document.getElementById('cl-loading')!;
    const errorEl = document.getElementById('cl-error')!;
    try {
      const res = await fetch(`/api/admin/contenuti/${tipo}/list`, { headers: { Authorization: `Bearer ${accessToken}` } });
      const data = await res.json();
      loadingEl.classList.add('hidden');
      if (!res.ok) {
        errorEl.textContent = data.message || 'Errore nel caricamento.';
        errorEl.classList.remove('hidden');
        return;
      }
      righeComplete = data.righe ?? [];
      if (data.nota) {
        const notaEl = document.getElementById('cl-nota')!;
        notaEl.textContent = data.nota;
        notaEl.classList.remove('hidden');
      }
      render();
    } catch (err) {
      loadingEl.classList.add('hidden');
      errorEl.textContent = String((err as Error)?.message ?? err);
      errorEl.classList.remove('hidden');
    }
  });
</script>
