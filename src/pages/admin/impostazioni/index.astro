---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---
<AdminLayout titolo="Impostazioni del sito" minRole="super_admin">
  <div class="mx-auto max-w-3xl">
    <h1 class="text-xl font-bold text-slate-900">Impostazioni del sito</h1>
    <p class="mt-1 text-sm text-slate-600">
      Contatti, social, banner e modalità manutenzione mostrati sulle pagine pubbliche. Ogni salvataggio crea un commit
      su GitHub e sarà visibile in produzione dopo il prossimo deploy.
    </p>

    <div id="impostazioni-loading" class="mt-6 text-sm text-slate-500">Caricamento…</div>
    <div id="impostazioni-forbidden" class="mt-6 hidden rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">
      Solo un Super Admin può gestire le impostazioni del sito.
    </div>

    <form id="impostazioni-form" class="mt-6 hidden space-y-8">

      <fieldset class="rounded-2xl border border-slate-200 bg-white p-6">
        <legend class="px-1 text-sm font-bold uppercase tracking-wide text-slate-500">Identità</legend>
        <div class="mt-4 grid gap-4 sm:grid-cols-2">
          <div>
            <label class="block text-sm font-semibold text-slate-800">Nome</label>
            <input name="nome" required maxlength="80" class="mt-1.5 w-full rounded-xl border border-slate-300 px-4 py-2.5 text-sm" />
          </div>
          <div>
            <label class="block text-sm font-semibold text-slate-800">Città / Università</label>
            <input name="cittaUniversita" maxlength="120" class="mt-1.5 w-full rounded-xl border border-slate-300 px-4 py-2.5 text-sm" />
          </div>
          <div class="sm:col-span-2">
            <label class="block text-sm font-semibold text-slate-800">Slogan</label>
            <input name="slogan" maxlength="200" class="mt-1.5 w-full rounded-xl border border-slate-300 px-4 py-2.5 text-sm" />
          </div>
          <div class="sm:col-span-2">
            <label class="block text-sm font-semibold text-slate-800">Descrizione (anche default SEO)</label>
            <textarea name="descrizione" required maxlength="300" rows="3" class="mt-1.5 w-full rounded-xl border border-slate-300 px-4 py-2.5 text-sm"></textarea>
          </div>
        </div>
      </fieldset>

      <fieldset class="rounded-2xl border border-slate-200 bg-white p-6">
        <legend class="px-1 text-sm font-bold uppercase tracking-wide text-slate-500">Contatti</legend>
        <div class="mt-4 grid gap-4 sm:grid-cols-2">
          <div>
            <label class="block text-sm font-semibold text-slate-800">Email</label>
            <input name="email" type="email" required class="mt-1.5 w-full rounded-xl border border-slate-300 px-4 py-2.5 text-sm" />
          </div>
          <div>
            <label class="block text-sm font-semibold text-slate-800">Telefono</label>
            <input name="telefono" maxlength="40" class="mt-1.5 w-full rounded-xl border border-slate-300 px-4 py-2.5 text-sm" />
          </div>
          <div class="sm:col-span-2">
            <label class="block text-sm font-semibold text-slate-800">Indirizzo</label>
            <input name="indirizzo" maxlength="200" class="mt-1.5 w-full rounded-xl border border-slate-300 px-4 py-2.5 text-sm" />
          </div>
        </div>
      </fieldset>

      <fieldset class="rounded-2xl border border-slate-200 bg-white p-6">
        <legend class="px-1 text-sm font-bold uppercase tracking-wide text-slate-500">Social e form esterni</legend>
        <div class="mt-4 grid gap-4 sm:grid-cols-2">
          <div><label class="block text-sm font-semibold text-slate-800">Instagram</label><input name="social.instagram" class="mt-1.5 w-full rounded-xl border border-slate-300 px-4 py-2.5 text-sm" /></div>
          <div><label class="block text-sm font-semibold text-slate-800">Facebook</label><input name="social.facebook" class="mt-1.5 w-full rounded-xl border border-slate-300 px-4 py-2.5 text-sm" /></div>
          <div><label class="block text-sm font-semibold text-slate-800">Telegram</label><input name="social.telegram" class="mt-1.5 w-full rounded-xl border border-slate-300 px-4 py-2.5 text-sm" /></div>
          <div><label class="block text-sm font-semibold text-slate-800">YouTube</label><input name="social.youtube" class="mt-1.5 w-full rounded-xl border border-slate-300 px-4 py-2.5 text-sm" /></div>
          <div><label class="block text-sm font-semibold text-slate-800">WhatsApp principale</label><input name="social.whatsapp" class="mt-1.5 w-full rounded-xl border border-slate-300 px-4 py-2.5 text-sm" /></div>
          <div><label class="block text-sm font-semibold text-slate-800">Form segnalazioni (URL)</label><input name="form.segnalazioni" class="mt-1.5 w-full rounded-xl border border-slate-300 px-4 py-2.5 text-sm" /></div>
          <div><label class="block text-sm font-semibold text-slate-800">Form "Entra" (URL)</label><input name="form.entra" class="mt-1.5 w-full rounded-xl border border-slate-300 px-4 py-2.5 text-sm" /></div>
        </div>
      </fieldset>

      <fieldset class="rounded-2xl border border-slate-200 bg-white p-6">
        <legend class="px-1 text-sm font-bold uppercase tracking-wide text-slate-500">Banner sitewide</legend>
        <p class="mt-1 text-xs text-slate-500">Avviso temporaneo mostrato in cima a ogni pagina pubblica.</p>
        <div class="mt-4 space-y-4">
          <label class="flex items-center gap-2 text-sm font-medium text-slate-800">
            <input type="checkbox" name="banner.attivo" class="h-4 w-4 rounded border-slate-300" /> Banner attivo
          </label>
          <div>
            <label class="block text-sm font-semibold text-slate-800">Messaggio</label>
            <input name="banner.messaggio" maxlength="300" class="mt-1.5 w-full rounded-xl border border-slate-300 px-4 py-2.5 text-sm" />
          </div>
          <div>
            <label class="block text-sm font-semibold text-slate-800">Link (opzionale)</label>
            <input name="banner.link" maxlength="300" class="mt-1.5 w-full rounded-xl border border-slate-300 px-4 py-2.5 text-sm" />
          </div>
        </div>
      </fieldset>

      <fieldset class="rounded-2xl border border-amber-200 bg-amber-50 p-6">
        <legend class="px-1 text-sm font-bold uppercase tracking-wide text-amber-700">Modalità manutenzione (solo avviso, non blocca l'accesso)</legend>
        <div class="mt-4 space-y-4">
          <label class="flex items-center gap-2 text-sm font-medium text-slate-800">
            <input type="checkbox" name="manutenzione.attiva" class="h-4 w-4 rounded border-slate-300" /> Mostra avviso di manutenzione
          </label>
          <div>
            <label class="block text-sm font-semibold text-slate-800">Messaggio</label>
            <input name="manutenzione.messaggio" maxlength="300" class="mt-1.5 w-full rounded-xl border border-slate-300 px-4 py-2.5 text-sm" />
          </div>
        </div>
      </fieldset>

      <div id="impostazioni-errore" role="alert" class="hidden rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800"></div>

      <button type="submit" id="impostazioni-salva" class="rounded-xl bg-primary-800 px-6 py-3 text-sm font-semibold text-white hover:bg-primary-700 disabled:cursor-not-allowed disabled:bg-slate-300">
        Salva impostazioni
      </button>
    </form>
  </div>
</AdminLayout>

<script>
  import { onAdminReady } from '../../../lib/admin/ready';

  onAdminReady(({ accessToken }) => {
    const loadingEl = document.getElementById('impostazioni-loading')!;
    const forbiddenEl = document.getElementById('impostazioni-forbidden')!;
    const form = document.getElementById('impostazioni-form') as HTMLFormElement;
    const erroreEl = document.getElementById('impostazioni-errore')!;
    const btnSalva = document.getElementById('impostazioni-salva') as HTMLButtonElement;

    function setByPath(obj: any, path: string, value: any) {
      const parts = path.split('.');
      let cur = obj;
      for (let i = 0; i < parts.length - 1; i++) cur = cur[parts[i]] ??= {};
      cur[parts[parts.length - 1]] = value;
    }
    function getByPath(obj: any, path: string) {
      return path.split('.').reduce((cur, k) => (cur == null ? undefined : cur[k]), obj);
    }

    function popolaForm(dati: any) {
      form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('[name]').forEach((el) => {
        const val = getByPath(dati, el.name);
        if (el instanceof HTMLInputElement && el.type === 'checkbox') {
          el.checked = Boolean(val);
        } else {
          el.value = val ?? '';
        }
      });
    }

    function leggiForm(): Record<string, unknown> {
      const dati: Record<string, unknown> = {};
      form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('[name]').forEach((el) => {
        const val = el instanceof HTMLInputElement && el.type === 'checkbox' ? el.checked : el.value;
        setByPath(dati, el.name, val);
      });
      return dati;
    }

    async function carica() {
      if (!accessToken) return;
      const res = await fetch('/api/admin/settings', { headers: { Authorization: `Bearer ${accessToken}` } });
      if (res.status === 403) {
        loadingEl.classList.add('hidden');
        forbiddenEl.classList.remove('hidden');
        return;
      }
      if (!res.ok) {
        loadingEl.textContent = 'Errore nel caricamento delle impostazioni.';
        return;
      }
      const data = await res.json();
      popolaForm(data.impostazioni);
      loadingEl.classList.add('hidden');
      form.classList.remove('hidden');
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      erroreEl.classList.add('hidden');
      btnSalva.disabled = true;
      btnSalva.textContent = 'Salvataggio…';
      try {
        const res = await fetch('/api/admin/settings', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${accessToken}` },
          body: JSON.stringify(leggiForm()),
        });
        const data = await res.json();
        if (!res.ok) {
          erroreEl.textContent = data.message || data.error || 'Salvataggio fallito.';
          erroreEl.classList.remove('hidden');
          return;
        }
        (window as any).adminToast?.('Impostazioni salvate. Visibili dopo il prossimo deploy.');
      } catch (err) {
        erroreEl.textContent = String((err as Error)?.message ?? err);
        erroreEl.classList.remove('hidden');
      } finally {
        btnSalva.disabled = false;
        btnSalva.textContent = 'Salva impostazioni';
      }
    });

    carica();
  });
</script>
