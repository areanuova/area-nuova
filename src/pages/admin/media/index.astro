---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---
<AdminLayout titolo="Media" minRole="editor">
  <div class="mx-auto max-w-6xl">
    <h1 class="text-xl font-bold text-slate-900">Media library</h1>
    <p class="mt-1 text-sm text-slate-600">Immagini, QR e documenti caricati dal pannello. Copia il percorso per usarlo nei campi "immagine" dei contenuti.</p>

    <div id="media-non-disponibile" class="mt-4 hidden rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800">
      La media library non è ancora attiva in questo ambiente (migration Sprint 5.0B non applicata).
    </div>

    <div id="media-dropzone" class="mt-6 rounded-2xl border-2 border-dashed border-slate-300 bg-slate-50 p-8 text-center">
      <p class="text-sm text-slate-600">Trascina qui uno o più file, oppure</p>
      <label class="mt-2 inline-block cursor-pointer rounded-xl bg-primary-800 px-4 py-2 text-sm font-semibold text-white hover:bg-primary-700">
        Scegli file
        <input id="media-file-input" type="file" multiple accept="image/jpeg,image/png,image/webp,image/svg+xml,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document" class="hidden" />
      </label>
      <p class="mt-2 text-xs text-slate-400">Immagini, PDF, Word — max 15 MB per file.</p>
      <div id="media-upload-status" class="mt-3 space-y-1 text-xs text-slate-500"></div>
    </div>

    <div class="mt-6 flex flex-wrap items-center gap-3">
      <input id="media-search" placeholder="Cerca per nome file…" class="rounded-xl border border-slate-300 px-3 py-2 text-sm" />
      <select id="media-filter-tipo" class="rounded-xl border border-slate-300 px-3 py-2 text-sm">
        <option value="">Tutti i formati</option>
        <option value="image">Immagini</option>
        <option value="pdf">PDF</option>
        <option value="doc">Word</option>
      </select>
      <span id="media-totale" class="text-sm text-slate-500"></span>
    </div>

    <div id="media-grid" class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-4"></div>
  </div>
</AdminLayout>

<script>
  import { onAdminReady } from '../../../lib/admin/ready';

  const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL as string;
  function urlPubblico(path: string): string {
    return `${SUPABASE_URL}/storage/v1/object/public/cms-media/${path}`;
  }

  onAdminReady(({ accessToken }) => {
    const grid = document.getElementById('media-grid')!;
    const nonDisponibile = document.getElementById('media-non-disponibile')!;
    const totaleEl = document.getElementById('media-totale')!;
    const searchInput = document.getElementById('media-search') as HTMLInputElement;
    const filterTipo = document.getElementById('media-filter-tipo') as HTMLSelectElement;
    const uploadStatus = document.getElementById('media-upload-status')!;
    const fileInput = document.getElementById('media-file-input') as HTMLInputElement;
    const dropzone = document.getElementById('media-dropzone')!;

    function iconaPer(mime: string): string {
      if (mime.startsWith('image/')) return '🖼️';
      if (mime === 'application/pdf') return '📄';
      return '📝';
    }
    function formattaDimensione(bytes: number): string {
      if (bytes < 1024) return `${bytes} B`;
      if (bytes < 1024 * 1024) return `${Math.round(bytes / 1024)} KB`;
      return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;
    }

    async function carica() {
      if (!accessToken) return;
      const params = new URLSearchParams();
      if (searchInput.value.trim()) params.set('q', searchInput.value.trim());
      if (filterTipo.value) params.set('tipo', filterTipo.value);

      const res = await fetch(`/api/admin/media/list?${params}`, { headers: { Authorization: `Bearer ${accessToken}` } });
      const data = await res.json();

      if (!res.ok) return;
      if (!data.disponibile) {
        nonDisponibile.classList.remove('hidden');
        return;
      }
      nonDisponibile.classList.add('hidden');
      totaleEl.textContent = `${data.totale} file`;

      grid.innerHTML = (data.file ?? []).map((m: any) => `
        <div class="rounded-2xl border border-slate-200 bg-white p-3" data-id="${m.id}">
          ${m.mime_type.startsWith('image/')
            ? `<div class="aspect-video overflow-hidden rounded-lg bg-slate-100"><img src="${urlPubblico(m.path)}" alt="${m.alt_text ?? ''}" class="h-full w-full object-cover" loading="lazy" /></div>`
            : `<div class="grid aspect-video place-items-center rounded-lg bg-slate-100 text-3xl">${iconaPer(m.mime_type)}</div>`}
          <p class="mt-2 truncate text-xs font-semibold text-slate-800" title="${m.filename}">${m.filename}</p>
          <p class="text-xs text-slate-400">${formattaDimensione(m.size_bytes)} · ${new Date(m.created_at).toLocaleDateString('it-IT')}</p>
          <p class="mt-1 text-xs ${m.inUso ? 'text-accent-700' : 'text-slate-400'}">${m.inUso ? 'In uso' : 'Non utilizzato'}</p>
          <input class="media-alt-input mt-2 w-full rounded-lg border border-slate-200 px-2 py-1 text-xs" placeholder="Testo alternativo" value="${m.alt_text ?? ''}" />
          <div class="mt-2 flex flex-wrap gap-1.5">
            <button type="button" class="media-copy-btn rounded-lg border border-slate-300 px-2 py-1 text-xs font-semibold text-slate-700 hover:border-primary-500">Copia URL</button>
            <button type="button" class="media-delete-btn rounded-lg border px-2 py-1 text-xs font-semibold ${m.inUso ? 'cursor-not-allowed border-slate-200 text-slate-300' : 'border-red-300 text-red-700 hover:bg-red-50'}" ${m.inUso ? 'disabled title="In uso: non eliminabile"' : ''}>Elimina</button>
          </div>
        </div>`).join('') || '<p class="col-span-full py-8 text-center text-sm text-slate-400">Nessun file caricato.</p>';

      grid.querySelectorAll<HTMLElement>('[data-id]').forEach((card) => {
        const id = card.dataset.id!;
        const path = (data.file.find((m: any) => m.id === id) ?? {}).path;

        card.querySelector('.media-copy-btn')?.addEventListener('click', async () => {
          await navigator.clipboard.writeText(urlPubblico(path));
          (window as any).adminToast?.('URL copiato.');
        });

        card.querySelector('.media-delete-btn')?.addEventListener('click', async (e) => {
          const btn = e.currentTarget as HTMLButtonElement;
          if (btn.disabled) return;
          if (!confirm('Eliminare definitivamente questo file? Non è recuperabile.')) return;
          const res = await fetch(`/api/admin/media/${id}`, { method: 'DELETE', headers: { Authorization: `Bearer ${accessToken}` } });
          const d = await res.json();
          if (!res.ok) { (window as any).adminToast?.(d.message || d.error, 'error'); return; }
          (window as any).adminToast?.('File eliminato.');
          carica();
        });

        card.querySelector('.media-alt-input')?.addEventListener('change', async (e) => {
          const val = (e.target as HTMLInputElement).value;
          await fetch(`/api/admin/media/${id}`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${accessToken}` },
            body: JSON.stringify({ altText: val }),
          });
          (window as any).adminToast?.('Testo alternativo aggiornato.');
        });
      });
    }

    async function caricaFile(files: FileList | File[]) {
      for (const file of Array.from(files)) {
        const riga = document.createElement('p');
        riga.textContent = `${file.name} — caricamento…`;
        uploadStatus.appendChild(riga);

        const fd = new FormData();
        fd.append('file', file);
        try {
          const res = await fetch('/api/admin/media/upload', {
            method: 'POST',
            headers: { Authorization: `Bearer ${accessToken}` },
            body: fd,
          });
          const data = await res.json();
          riga.textContent = res.ok ? `${file.name} — caricato.` : `${file.name} — errore: ${data.message || data.error}`;
        } catch (err) {
          riga.textContent = `${file.name} — errore: ${String((err as Error)?.message ?? err)}`;
        }
      }
      setTimeout(() => { uploadStatus.innerHTML = ''; }, 5000);
      carica();
    }

    fileInput.addEventListener('change', () => { if (fileInput.files) caricaFile(fileInput.files); fileInput.value = ''; });
    dropzone.addEventListener('dragover', (e) => { e.preventDefault(); dropzone.classList.add('border-primary-500'); });
    dropzone.addEventListener('dragleave', () => dropzone.classList.remove('border-primary-500'));
    dropzone.addEventListener('drop', (e) => {
      e.preventDefault();
      dropzone.classList.remove('border-primary-500');
      if (e.dataTransfer?.files?.length) caricaFile(e.dataTransfer.files);
    });

    searchInput.addEventListener('input', () => { clearTimeout((window as any).__mediaSearchDebounce); (window as any).__mediaSearchDebounce = setTimeout(carica, 300); });
    filterTipo.addEventListener('change', carica);

    carica();
  });
</script>
