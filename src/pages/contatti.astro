---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import sito from '../data/sito.json';
---

<BaseLayout titolo="Contatti" descrizione="Come contattare Area Nuova.">
  <PageHeader occhiello="Scrivici" titolo="Contatti" sottotitolo="Hai bisogno di aiuto o vuoi collaborare? Siamo a disposizione." />

  <section class="container-site py-16">
    <div class="grid gap-6 md:grid-cols-2">
      <div class="rounded-2xl bg-white p-8 shadow-sm ring-1 ring-slate-200">
        <h2 class="text-xl font-bold">Email</h2>
        <a href={`mailto:${sito.email}`} class="mt-2 inline-block text-lg font-semibold text-primary-800 hover:underline">{sito.email}</a>
        <h3 class="mt-8 text-sm font-semibold uppercase tracking-wide text-slate-500">Seguici</h3>
        <div class="mt-3 flex flex-wrap gap-3">
          {sito.social.instagram && <a href={sito.social.instagram} class="rounded-lg bg-slate-100 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-200">Instagram</a>}
          {sito.social.facebook && <a href={sito.social.facebook} class="rounded-lg bg-slate-100 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-200">Facebook</a>}
          {sito.social.telegram && <a href={sito.social.telegram} class="rounded-lg bg-slate-100 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-200">Telegram</a>}
        </div>
      </div>

      <div class="rounded-2xl bg-primary-50 p-8">
        <h2 class="text-xl font-bold text-primary-900">Link rapidi</h2>
        <ul class="mt-4 space-y-3">
          <li><a href="/segnalazioni" class="font-semibold text-primary-800 hover:underline">→ Invia una segnalazione</a></li>
          <li><a href="/entra" class="font-semibold text-primary-800 hover:underline">→ Entra in Area Nuova</a></li>
          <li><a href="/modulistica" class="font-semibold text-primary-800 hover:underline">→ Modulistica e documenti</a></li>
          <li><a href="/guide" class="font-semibold text-primary-800 hover:underline">→ Guide utili</a></li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
