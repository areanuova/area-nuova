---
import '../styles/global.css';
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';
// Aris (assistente AI) temporaneamente disattivato: componente non rimosso, solo scollegato.
// Per ripristinarlo: reimportare ArisWidget da '../components/aris/ArisWidget.astro' e rimontarlo qui sotto.
import sito from '../data/sito.json';

interface Props {
  titolo: string;
  descrizione?: string;
}

const { titolo, descrizione = sito.descrizione } = Astro.props;
const titoloPagina = `${titolo} · ${sito.nome}`;
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{titoloPagina}</title>
    <meta name="description" content={descrizione} />

    <!-- Open Graph (anteprime sui social) -->
    <meta property="og:title" content={titoloPagina} />
    <meta property="og:description" content={descrizione} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="it_IT" />
  </head>
  <body class="flex min-h-screen flex-col">
    {sito.manutenzione?.attiva && (
      <div class="bg-amber-500 px-4 py-2 text-center text-sm font-semibold text-white">
        {sito.manutenzione.messaggio || 'Stiamo effettuando alcuni aggiornamenti.'}
      </div>
    )}
    {sito.banner?.attivo && sito.banner.messaggio && (
      <div class="bg-primary-800 px-4 py-2 text-center text-sm text-white">
        {sito.banner.link ? (
          <a href={sito.banner.link} class="underline hover:no-underline">{sito.banner.messaggio}</a>
        ) : (
          sito.banner.messaggio
        )}
      </div>
    )}
    <Navbar />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
